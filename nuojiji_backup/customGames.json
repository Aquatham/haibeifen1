[{"title":"塔罗禁忌版","description":"","icon":"🔮","coverColor":"#9F7AEA","htmlContent":"<!DOCTYPE html>\r\n<html lang=\"zh\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\r\n<title>欲望塔罗 · 禁忌之章</title>\r\n<style>\r\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Noto+Serif+SC:wght@300;400;600&display=swap');\r\n\r\n  :root {\r\n    --gold: #d4af37;\r\n    --card-h: 460px;\r\n    --card-w: 290px;\r\n  }\r\n\r\n  * { margin: 0; padding: 0; box-sizing: border-box; }\r\n\r\n  body {\r\n    min-height: 100vh;\r\n    background: radial-gradient(circle at center, #1a051d 0%, #05010a 100%);\r\n    font-family: 'Noto Serif SC', serif;\r\n    color: #f0e6ff;\r\n    overflow-x: hidden;\r\n  }\r\n\r\n  .stars {\r\n    position: fixed; inset: 0; pointer-events: none; z-index: 0;\r\n    background-image: radial-gradient(1px 1px at 20% 30%, #fff, transparent), radial-gradient(1px 1px at 70% 80%, #d4af37, transparent);\r\n  }\r\n\r\n  .container {\r\n    position: relative; z-index: 1;\r\n    max-width: 1000px; margin: 0 auto;\r\n    padding: 40px 16px;\r\n    display: flex; flex-direction: column; align-items: center; gap: 40px;\r\n  }\r\n\r\n  .header { text-align: center; }\r\n  .title {\r\n    font-family: 'Cinzel Decorative', serif;\r\n    font-size: clamp(2rem, 6vw, 3.5rem);\r\n    background: linear-gradient(to right, #ff0055, #d4af37, #7b2fbe);\r\n    -webkit-background-clip: text; -webkit-text-fill-color: transparent;\r\n    filter: drop-shadow(0 0 15px rgba(255,0,85,0.4));\r\n  }\r\n  .subtitle { margin-top: 10px; font-size: 0.8rem; letter-spacing: 0.5em; color: rgba(212,175,55,0.6); }\r\n\r\n  .decks { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; width: 100%; }\r\n  .deck-btn {\r\n    position: relative; padding: 18px 25px; border: none; border-radius: 4px;\r\n    cursor: pointer; font-family: 'Noto Serif SC', serif; color: #fff;\r\n    background: rgba(40, 10, 50, 0.6); border: 1px solid rgba(212,175,55,0.4);\r\n    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\r\n    min-width: 160px;\r\n  }\r\n  .deck-btn:hover {\r\n    transform: scale(1.05); border-color: #ff0055;\r\n    box-shadow: 0 0 30px rgba(255,0,85,0.3);\r\n  }\r\n  .deck-sub { display: block; font-size: 0.6rem; opacity: 0.6; margin-top: 5px; letter-spacing: 0.2em; }\r\n\r\n  .stage { width: 100%; min-height: 500px; display: flex; flex-direction: column; align-items: center; }\r\n  .card-table { display: flex; flex-wrap: wrap; justify-content: center; gap: 25px; width: 100%; margin-top: 20px;}\r\n\r\n  .card-wrap { width: var(--card-w); height: var(--card-h); perspective: 1500px; }\r\n  .card-inner {\r\n    width: 100%; height: 100%; position: relative;\r\n    transform-style: preserve-3d; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);\r\n  }\r\n  .card-wrap.flipped .card-inner { transform: rotateY(180deg); }\r\n\r\n  .card-back {\r\n    position: absolute; inset: 0; border-radius: 15px;\r\n    background: #0d0216; backface-visibility: hidden;\r\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\r\n    border: 3px solid #1e0a2d; box-shadow: 0 15px 40px rgba(0,0,0,0.9);\r\n    overflow: hidden;\r\n  }\r\n  .card-back::before {\r\n    content: ''; position: absolute; inset: 10px;\r\n    border: 1px solid rgba(212,175,55,0.2); border-radius: 10px;\r\n  }\r\n  .mandala {\r\n    width: 160px; height: 160px; border: 1px double rgba(212,175,55,0.3);\r\n    border-radius: 50%; display: flex; align-items: center; justify-content: center;\r\n    animation: rotate 15s linear infinite;\r\n  }\r\n  @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\r\n  .mandala::after { content: '◈'; color: #d4af37; font-size: 2.5rem; filter: drop-shadow(0 0 10px #d4af37); }\r\n\r\n  .card-front {\r\n    position: absolute; inset: 0; border-radius: 15px;\r\n    backface-visibility: hidden; transform: rotateY(180deg);\r\n    padding: 30px 20px; text-align: center;\r\n    background: #0a0110; display: flex; flex-direction: column; justify-content: center;\r\n  }\r\n  .type-1 { border: 2px solid #ff0055; box-shadow: inset 0 0 40px rgba(255,0,85,0.3); }\r\n  .type-2 { border: 2px solid #7b2fbe; box-shadow: inset 0 0 40px rgba(123,47,190,0.3); }\r\n  .type-3 { border: 2px solid #ff6b35; box-shadow: inset 0 0 40px rgba(255,107,53,0.3); }\r\n\r\n  .card-icon { font-size: 3rem; margin-bottom: 20px; }\r\n  .card-name { font-size: 1.3rem; margin-bottom: 15px; font-weight: 600; color: #fff; letter-spacing: 3px;}\r\n  .card-desc { font-size: 0.9rem; line-height: 1.7; color: #e0d0ff; text-align: justify; word-break: break-all; }\r\n  .card-tag { position: absolute; bottom: 20px; font-size: 0.7rem; color: var(--gold); opacity: 0.5; letter-spacing: 3px; width: 100%; left: 0; text-align: center; }\r\n\r\n  .controls { margin-top: 40px; display: flex; gap: 20px; }\r\n  .btn-clear {\r\n    padding: 10px 25px; background: none; border: 1px solid rgba(255,255,255,0.2);\r\n    color: #aaa; cursor: pointer; border-radius: 20px; transition: 0.3s;\r\n  }\r\n  .btn-clear:hover { color: #fff; border-color: #fff; }\r\n\r\n</style>\r\n</head>\r\n<body>\r\n\r\n<div class=\"stars\"></div>\r\n\r\n<div class=\"container\">\r\n  <div class=\"header\">\r\n    <h1 class=\"title\">欲望塔罗</h1>\r\n    <p class=\"subtitle\">UNLEASH THE BEAST</p>\r\n  </div>\r\n\r\n  <div class=\"decks\">\r\n    <button class=\"deck-btn\" onclick=\"drawCard(1)\">\r\n      <span>⚔️ 侵略 · 序章</span>\r\n      <span class=\"deck-sub\">INVADE</span>\r\n    </button>\r\n    <button class=\"deck-btn\" onclick=\"drawCard(2)\">\r\n      <span>🔗 支配 · 正剧</span>\r\n      <span class=\"deck-sub\">DOMINATE</span>\r\n    </button>\r\n    <button class=\"deck-btn\" onclick=\"drawCard(3)\">\r\n      <span>⛓️ 堕落 · 终章</span>\r\n      <span class=\"deck-sub\">SURRENDER</span>\r\n    </button>\r\n  </div>\r\n\r\n  <div class=\"stage\">\r\n    <div class=\"card-table\" id=\"cardTable\"></div>\r\n  </div>\r\n\r\n  <div class=\"controls\">\r\n    <button class=\"btn-clear\" onclick=\"clearTable()\">清空桌面</button>\r\n  </div>\r\n</div>\r\n\r\n<script>\r\nconst DECKS = {\r\n  1: { type: 'type-1', tag: 'INVADE', cards: [\r\n    { icon: '💋', name: '掠夺性吻', desc: '不要温柔，直接咬住对方的下唇。直到尝到一丝铁锈味，或者听到对方无法自抑的破碎呻吟。' },\r\n    { icon: '🖐️', name: '锁喉掌控', desc: '虎口抵住对方的咽喉，稍微用力。让对方在缺氧的边缘，只能通过你的给予来呼吸。' },\r\n    { icon: '🥃', name: '烈酒浇灌', desc: '含一口冰冷的烈酒，俯身渡进对方口中。在辛辣与炙热的冲撞里，夺走对方所有的思考能力。' },\r\n    { icon: '👠', name: '绝对服从', desc: '用指尖划过对方最敏感的区域，却在对方即将爆发时猛然停下手，命令他/她：“不准动，看着我。”' },\r\n    { icon: '🍷', name: '禁忌低语', desc: '在对方耳后根最敏感处，用牙齿轻磨肉感。用最轻的声音说出最下流的预告。' },\r\n    { icon: '🧶', name: '领地巡视', desc: '粗暴地扯下对方的领带或丝巾，缠绕在你的指尖。那是你宣示主权的绳索。' },\r\n    { icon: '🧊', name: '冰火洗礼', desc: '将冰块含在口中，贴上对方滚烫的颈项。冷热交替的瞬间，捕捉对方那一秒的战栗。' },\r\n    { icon: '🚪', name: '暗室困局', desc: '将对方推入无人的角落，用身体将其死死封锁。在黑暗中，你就是对方唯一的感官来源。' },\r\n    { icon: '🚬', name: '尼古丁吻', desc: '将最后一口烟雾吐在对方脸上，在对方视线模糊时，粗暴地入侵对方的口腔。' },\r\n    { icon: '🖤', name: '掠夺凝视', desc: '强迫对方直视你的眼睛。那是猎食者的眼神，要让对方从灵魂深处感到自己正在被拆解。' },\r\n    { icon: '🧤', name: '丝绒触碰', desc: '戴上手套抚摸对方。隔着织物的触碰比直接接触更让人焦躁，那是克制背后的疯狂。' },\r\n    { icon: '🏹', name: '狩猎之弧', desc: '用手指勾起对方的下巴，力度要大到让其不得不被迫仰起头。欣赏那条脆弱且优美的颈线。' }\r\n  ]},\r\n  2: { type: 'type-2', tag: 'DOMINATE', cards: [\r\n    { icon: '🧱', name: '墙面挤压', desc: '将对方双腕反扣压在墙上，胸膛死死抵住脊背。在对方耳边用最低沉的声音描述你接下来要进行的暴行。' },\r\n    { icon: '🐺', name: '野性标记', desc: '在对方颈侧或肩胛留下最深的齿痕。那是今晚的勋章，证明这具身体此刻完全属于谁。' },\r\n    { icon: '👗', name: '丝绒剥离', desc: '一件件剥掉障碍，每剥下一件都要伴随一次极具侵略性的抚摸。这种慢速的凌迟比结果更难熬。' },\r\n    { icon: '⛓️', name: '视线禁锢', desc: '蒙住对方的双眼。在完全黑暗的恐惧中，你每一次毫无预兆的触碰，都会在对方身上引起海啸般的颤栗。' },\r\n    { icon: '🔱', name: '刑具赏赐', desc: '拿出准备好的“玩具”，不急着使用，只是在对方敏感的边缘游走，等待对方开口求饶或渴求。' },\r\n    { icon: '⚖️', name: '节奏主宰', desc: '完全掌控频率。无论对方如何扭动、如何催促，你都要按照自己的步调，将其折磨到崩溃边缘。' },\r\n    { icon: '🕯️', name: '烛光审判', desc: '滴下低温蜡油，看着那些液态的火焰在对方皮肤上凝固。那是你刻下的痛感标记。' },\r\n    { icon: '🪞', name: '镜像羞耻', desc: '强迫对方看向镜子里的自己。看清自己那张被情欲折磨得支离破碎、甚至有些陌生的脸。' },\r\n    { icon: '🔔', name: '羞耻铃声', desc: '给对方戴上带有响动的小物。每一下轻微的动作都会发出声音，无时无刻不在提醒对方现在的处境。' },\r\n    { icon: '✒️', name: '躯体绘卷', desc: '用手指或湿润的笔尖，在对方身上画下属于你的名字。每一道划痕都要带起对方的一阵颤抖。' },\r\n    { icon: '🧎', name: '卑微服从', desc: '撤掉对方所有的支撑。让其只能依靠你的腿、你的手，甚至只能跪在你的脚边寻求呼吸。' },\r\n    { icon: '🌪️', name: '感官风暴', desc: '同时刺激对方的多个点，不给任何喘息的机会。让快感和痛感交织成网，将对方彻底淹没。' }\r\n  ]},\r\n  3: { type: 'type-3', tag: 'SURRENDER', cards: [\r\n    { icon: '🥀', name: '感官崩坏', desc: '找到那个让对方瞬间失神的临界点，然后反复、疯狂地碾压。直到对方瞳孔涣散，除了哭喊再也发不出完整音节。' },\r\n    { icon: '🔥', name: '燃尽仪式', desc: '不再留任何退路。今晚只有掠夺者和猎物，抛弃羞耻感，用最原始、最粗暴的方式宣泄所有的黑暗欲望。' },\r\n    { icon: '🌑', name: '深渊共沉', desc: '在最顶点的时候，逼迫对方直视你的眼睛。在那一刻，你们不是在相爱，是在互相吞噬，直到双双坠入黑暗。' },\r\n    { icon: '💦', name: '余温处刑', desc: '结束后不准离开，让汗水与气息交融。在对方最虚弱的时刻，在他/她耳边预告：下一次，会更过分。' },\r\n    { icon: '🌊', name: '潮汐淹没', desc: '在对方彻底失控时，拒绝停止。让那一波又一波的浪潮彻底冲垮对方的理智堤坝。' },\r\n    { icon: '🎭', name: '人格粉碎', desc: '在极度愉悦中诱导对方承认平时绝不会承认的癖好。看着那层自尊的伪装在情欲面前彻底粉碎。' },\r\n    { icon: '⚡', name: '过载短路', desc: '给予远超对方承受限度的刺激。让对方的大脑陷入一片空白，除了本能的痉挛，什么都不剩。' },\r\n    { icon: '🧪', name: '致命成瘾', desc: '在对方耳边重复暗示：你已经离不开这种痛苦和快乐了。你已经彻底坏掉了，只能由我来修补。' },\r\n    { icon: '🩸', name: '灵魂刻印', desc: '在最高潮时狠狠咬住对方。不仅要在肉体上留下痕迹，更要在对方的记忆里刻下终身难忘的烙印。' },\r\n    { icon: '🌧️', name: '雨后残墟', desc: '一切平息后，任由对方像破布偶一样瘫软。你用冰冷的指尖梳理对方汗湿的头发，那是胜者的仁慈。' },\r\n    { icon: '⛓️', name: '契约签订', desc: '用一个几乎窒息的吻作为今晚的句点。这不仅是结束，更是下一次更加疯狂折磨的契约。' },\r\n    { icon: '🌌', name: '永恒寂静', desc: '让对方在颤抖后的余温中沉睡。当他/她再次睁眼时，脑子里刻下的全是刚才那一幕幕地狱般的极乐。' }\r\n  ]}\r\n};\r\n\r\nfunction drawCard(deckId) {\r\n  const deck = DECKS[deckId];\r\n  const card = deck.cards[Math.floor(Math.random() * deck.cards.length)];\r\n  const id = Date.now();\r\n  \r\n  const table = document.getElementById('cardTable');\r\n  const wrap = document.createElement('div');\r\n  wrap.className = 'card-wrap';\r\n  wrap.id = 'card-' + id;\r\n  wrap.onclick = () => wrap.classList.toggle('flipped');\r\n  \r\n  wrap.innerHTML = `\r\n    <div class=\"card-inner\">\r\n      <div class=\"card-back\">\r\n        <div class=\"mandala\"></div>\r\n        <div style=\"margin-top:20px; color:#d4af37; font-size:0.7rem; letter-spacing:5px;\">FORBIDDEN</div>\r\n      </div>\r\n      <div class=\"card-face card-front ${deck.type}\">\r\n        <div class=\"card-icon\">${card.icon}</div>\r\n        <div class=\"card-name\">${card.name}</div>\r\n        <div class=\"card-desc\">${card.desc}</div>\r\n        <div class=\"card-tag\">${deck.tag}</div>\r\n      </div>\r\n    </div>\r\n  `;\r\n  table.appendChild(wrap);\r\n  \r\n  setTimeout(() => wrap.classList.add('flipped'), 100);\r\n}\r\n\r\nfunction clearTable() {\r\n  document.getElementById('cardTable').innerHTML = '';\r\n}\r\n</script>\r\n</body>\r\n</html>\r\n","usesAI":false,"createdAt":1783407942789,"id":1},{"title":"塔罗含蓄版","description":"","icon":"🔮","coverColor":"#805AD5","htmlContent":"<!DOCTYPE html>\r\n<html lang=\"zh\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\r\n<title>欲望塔罗 · 典藏版</title>\r\n<style>\r\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Noto+Serif+SC:wght@300;400;600&display=swap');\r\n\r\n  :root {\r\n    --pink: #f72585;\r\n    --violet: #7b2fbe;\r\n    --gold: #d4af37;\r\n    --deep: #0a0118;\r\n    --card-h: 440px;\r\n    --card-w: 280px;\r\n  }\r\n\r\n  * { margin: 0; padding: 0; box-sizing: border-box; }\r\n\r\n  body {\r\n    min-height: 100vh;\r\n    background: radial-gradient(circle at center, #1a0033 0%, #050010 100%);\r\n    font-family: 'Noto Serif SC', serif;\r\n    color: #f0e6ff;\r\n    overflow-x: hidden;\r\n  }\r\n\r\n  .stars {\r\n    position: fixed; inset: 0; pointer-events: none; z-index: 0;\r\n    background-image: \r\n      radial-gradient(1px 1px at 20% 30%, #fff, transparent),\r\n      radial-gradient(1.5px 1.5px at 70% 10%, rgba(212,175,55,0.4), transparent),\r\n      radial-gradient(1px 1px at 40% 80%, #fff, transparent);\r\n    background-size: 200% 200%;\r\n    animation: starMove 100s linear infinite;\r\n  }\r\n  @keyframes starMove { from {background-position: 0 0;} to {background-position: 100% 100%;} }\r\n\r\n  .container {\r\n    position: relative; z-index: 1;\r\n    max-width: 1000px; margin: 0 auto;\r\n    padding: 40px 16px;\r\n    display: flex; flex-direction: column; align-items: center; gap: 40px;\r\n  }\r\n\r\n  .header { text-align: center; }\r\n  .title {\r\n    font-family: 'Cinzel Decorative', serif;\r\n    font-size: clamp(2rem, 6vw, 3.2rem);\r\n    background: linear-gradient(to right, #d4af37, #f72585, #7b2fbe, #d4af37);\r\n    background-size: 300% auto;\r\n    -webkit-background-clip: text; -webkit-text-fill-color: transparent;\r\n    animation: gradShift 6s linear infinite;\r\n    filter: drop-shadow(0 0 15px rgba(212,175,55,0.3));\r\n  }\r\n  .subtitle {\r\n    margin-top: 10px; font-size: 0.8rem; letter-spacing: 0.4em;\r\n    color: rgba(212,175,55,0.6); text-transform: uppercase;\r\n  }\r\n\r\n  @keyframes gradShift { to { background-position: 300% center; } }\r\n\r\n  .decks { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; width: 100%; }\r\n  .deck-btn {\r\n    position: relative; padding: 16px 30px; border: none; border-radius: 4px;\r\n    cursor: pointer; font-family: 'Noto Serif SC', serif; color: #fff;\r\n    background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.3);\r\n    transition: all 0.4s; overflow: hidden; min-width: 180px;\r\n  }\r\n  .deck-btn:hover {\r\n    background: rgba(212,175,55,0.1); border-color: var(--gold);\r\n    box-shadow: 0 0 20px rgba(212,175,55,0.2); transform: translateY(-2px);\r\n  }\r\n  .deck-sub { display: block; font-size: 0.65rem; opacity: 0.6; margin-top: 4px; letter-spacing: 0.2em; }\r\n\r\n  .stage { width: 100%; min-height: 480px; position: relative; }\r\n  .empty-hint {\r\n    position: absolute; top: 100px; left: 50%; transform: translateX(-50%);\r\n    text-align: center; color: rgba(212,175,55,0.4); pointer-events: none; transition: 0.5s;\r\n  }\r\n  .card-table { display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; width: 100%; margin-top: 20px;}\r\n\r\n  .card-wrap {\r\n    width: var(--card-w); height: var(--card-h);\r\n    perspective: 1500px; cursor: pointer;\r\n  }\r\n  .card-inner {\r\n    width: 100%; height: 100%; position: relative;\r\n    transform-style: preserve-3d; transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);\r\n  }\r\n  .card-wrap.flipped .card-inner { transform: rotateY(180deg); }\r\n\r\n  .card-back {\r\n    position: absolute; inset: 0; border-radius: 12px;\r\n    background: radial-gradient(circle at center, #1a0b2e 0%, #05010d 100%);\r\n    backface-visibility: hidden;\r\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\r\n    border: 2px solid #2a1b3d; box-shadow: 0 10px 30px rgba(0,0,0,0.8); overflow: hidden;\r\n  }\r\n  .card-back::before {\r\n    content: ''; position: absolute; inset: 12px;\r\n    border: 1px solid rgba(212,175,55,0.3); border-radius: 8px;\r\n  }\r\n  .back-mandala {\r\n    position: relative; width: 160px; height: 160px;\r\n    display: flex; align-items: center; justify-content: center;\r\n  }\r\n  .mandala-ring {\r\n    position: absolute; inset: 0; border: 1px dashed rgba(212,175,55,0.2); border-radius: 50%;\r\n    animation: rotateClockwise 20s linear infinite;\r\n  }\r\n  .mandala-inner {\r\n    position: absolute; inset: 30px; border: 1px solid rgba(212,175,55,0.3); border-radius: 50%;\r\n    display: flex; align-items: center; justify-content: center;\r\n  }\r\n  .mandala-inner::after {\r\n    content: '✵'; color: var(--gold); font-size: 2.5rem;\r\n    filter: drop-shadow(0 0 10px rgba(212,175,55,0.8));\r\n    animation: breathe 4s ease-in-out infinite;\r\n  }\r\n  @keyframes rotateClockwise { from {transform: rotate(0deg);} to {transform: rotate(360deg);} }\r\n  @keyframes breathe { 0%, 100% { opacity: 0.6; transform: scale(1); } 50% { opacity: 1; transform: scale(1.1); } }\r\n\r\n  .card-front {\r\n    position: absolute; inset: 0; border-radius: 12px;\r\n    backface-visibility: hidden; transform: rotateY(180deg);\r\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\r\n    padding: 35px 25px; text-align: center; background: #0c011a;\r\n  }\r\n  .type-1 { border: 1.5px solid var(--pink); box-shadow: inset 0 0 40px rgba(247,37,133,0.15); }\r\n  .type-2 { border: 1.5px solid var(--violet); box-shadow: inset 0 0 40px rgba(123,47,190,0.15); }\r\n  .type-3 { border: 1.5px solid var(--gold); box-shadow: inset 0 0 40px rgba(212,175,55,0.15); }\r\n\r\n  .card-icon { font-size: 3rem; margin-bottom: 25px; filter: drop-shadow(0 0 10px rgba(255,255,255,0.2)); }\r\n  .card-name { font-size: 1.2rem; margin-bottom: 20px; color: #fff; letter-spacing: 0.2em; font-weight: 600;}\r\n  .card-desc { font-size: 0.9rem; line-height: 1.8; color: rgba(240,230,255,0.85); text-align: justify; }\r\n  .card-tag { position: absolute; bottom: 25px; font-size: 0.65rem; color: var(--gold); opacity: 0.5; letter-spacing: 0.4em; }\r\n\r\n  .controls { display: flex; gap: 15px; margin-top: 40px; }\r\n  .ctrl-btn {\r\n    padding: 10px 25px; background: transparent; border: 1px solid rgba(255,255,255,0.1);\r\n    color: rgba(255,255,255,0.5); border-radius: 30px; cursor: pointer; font-size: 0.8rem;\r\n    transition: 0.3s;\r\n  }\r\n  .ctrl-btn:hover { border-color: var(--gold); color: var(--gold); background: rgba(212,175,55,0.05); }\r\n\r\n  @media (max-width: 600px) {\r\n    :root { --card-w: 240px; --card-h: 380px; }\r\n    .decks { gap: 10px; }\r\n    .deck-btn { padding: 12px 20px; min-width: 140px; }\r\n  }\r\n</style>\r\n</head>\r\n<body>\r\n\r\n<div class=\"stars\"></div>\r\n\r\n<div class=\"container\">\r\n  <div class=\"header\">\r\n    <h1 class=\"title\">欲望塔罗</h1>\r\n    <p class=\"subtitle\">THE ARCANA OF DESIRE</p>\r\n  </div>\r\n\r\n  <div class=\"decks\">\r\n    <button class=\"deck-btn\" onclick=\"drawCard(1)\">\r\n      <span>✦ 序章 · 撩拨</span>\r\n      <span class=\"deck-sub\">AWAKENING</span>\r\n    </button>\r\n    <button class=\"deck-btn\" onclick=\"drawCard(2)\">\r\n      <span>❋ 正剧 · 缠绵</span>\r\n      <span class=\"deck-sub\">ENTANGLEMENT</span>\r\n    </button>\r\n    <button class=\"deck-btn\" onclick=\"drawCard(3)\">\r\n      <span>⚡ 终章 · 燃尽</span>\r\n      <span class=\"deck-sub\">IGNITION</span>\r\n    </button>\r\n  </div>\r\n\r\n  <div class=\"stage\">\r\n    <div class=\"empty-hint\" id=\"emptyHint\">\r\n      <p>点击牌堆 · 开启今夜契约</p>\r\n    </div>\r\n    <div class=\"card-table\" id=\"cardTable\"></div>\r\n  </div>\r\n\r\n  <div class=\"controls\">\r\n    <button class=\"ctrl-btn\" onclick=\"clearTable()\">清空桌面</button>\r\n    <button class=\"ctrl-btn\" onclick=\"location.reload()\">重新洗牌</button>\r\n  </div>\r\n</div>\r\n\r\n<script>\r\nconst DECKS = {\r\n  1: { type: 'type-1', tag: 'AWAKENING', cards: [\r\n    { icon: '🌸', name: '初雪之吻', desc: '以指尖沿颈线缓缓描绘，停留在每一处令你颤抖的微小起伏，感知体温的升高。' },\r\n    { icon: '🕯️', name: '烛影低语', desc: '在摇曳的火光中，将呼吸散落在耳廓边缘，用最轻的声音吐露一个暧昧的词汇。' },\r\n    { icon: '🌙', name: '月色缠绕', desc: '发丝不经意地扫过你的手心，像是一场无声的邀请，在寂静中放大每一寸感官。' },\r\n    { icon: '🍷', name: '红酒印记', desc: '冰凉的液体在锁骨处化开，用指尖勾勒那抹红润，在它坠落前将其轻柔捕获。' },\r\n    { icon: '🧤', name: '丝绒隔阂', desc: '隔着轻薄的织物抚摸，那种似有若无的阻碍感，反而让渴望在布料之下疯狂生长。' },\r\n    { icon: '🦋', name: '蝶翼振颤', desc: '睫毛轻触你的脸颊，如同蝴蝶扇动翅膀。在极近的距离下，听见彼此凌乱的呼吸。' },\r\n    { icon: '🍃', name: '微风轻叩', desc: '指腹若即若离地掠过掌心的纹路，像是在解读一封只有我们两人能懂的秘密情书。' },\r\n    { icon: '🌫️', name: '薄雾凝视', desc: '在烟霭缭绕中对视，直到对方的轮廓变得模糊，唯有那双充满渴求的眼睛愈发清晰。' },\r\n    { icon: '🪶', name: '羽毛试探', desc: '用最柔软的触碰挑逗最敏感的神经，在对方即将伸手抓住时，又灵巧地躲回暗处。' },\r\n    { icon: '🍫', name: '苦味甜美', desc: '分享一块高浓度的黑巧克力，在苦涩退去、甘甜上涌的瞬间，交换一个带有香气的吻。' },\r\n    { icon: '🩰', name: '无声序曲', desc: '赤足在绒毯上靠近，不发出一点声响。从背后轻轻环住，感受突如其来的心跳加速。' },\r\n    { icon: '🎐', name: '风铃回响', desc: '在对方颈后轻轻吹气，看那细小的绒毛竖起，享受这种掌控对方身体反应的快感。' }\r\n  ]},\r\n  2: { type: 'type-2', tag: 'ENTANGLEMENT', cards: [\r\n    { icon: '🌿', name: '藤蔓缠枝', desc: '肢体如生长千年的藤蔓般交错，分不清哪里是起点，哪里是终点，只有无尽的依附。' },\r\n    { icon: '🪞', name: '镜前共舞', desc: '在镜中审视彼此的沉溺。视觉的冲击让真实的情感无处遁形，每一个动作都被无限放大。' },\r\n    { icon: '🌊', name: '浪涌之间', desc: '节奏如同深海的潮汐，忽而平缓如叙事，忽而急促如奔逃，让理智被彻底淹没。' },\r\n    { icon: '⛓️', name: '金丝禁锢', desc: '手指交叠锁扣，不留一丝缝隙。这是一场名为“束缚”的温柔博弈，谁也不愿先行松开。' },\r\n    { icon: '🌌', name: '星云坠落', desc: '在绝对的黑暗中靠触觉丈量彼此，像是在荒芜的宇宙中寻找唯一的依靠，生死相随。' },\r\n    { icon: '💧', name: '雨夜共振', desc: '汗水与气息在湿润的空气中交融，心跳声在胸腔内共鸣，仿佛这世界只剩这一处避风港。' },\r\n    { icon: '🏹', name: '狩猎本能', desc: '在追逐与被追逐中变换角色。牙齿轻抵在最脆弱的血管上，那是危险又迷人的归属宣告。' },\r\n    { icon: '🖋️', name: '躯体铭刻', desc: '用指尖在脊椎上画下复杂的字符，像是在这具完美的艺术品上，烙印下独属于你的徽记。' },\r\n    { icon: '⌛', name: '沙漏停滞', desc: '在到达顶峰的前一刻突然静止。感受那种近在咫尺却又被刻意延迟的煎熬，美到令人窒息。' },\r\n    { icon: '🎻', name: '弦音颤动', desc: '你就像一把名贵的提琴，每一个按压和拨动，都会引发最动人、最破碎的低吟声。' },\r\n    { icon: '🧪', name: '化学反应', desc: '两种灵魂在狭小的空间内剧烈碰撞，产生出让人目眩神迷的香气，将一切伪装焚烧殆尽。' },\r\n    { icon: '🏺', name: '陶土重塑', desc: '像对待温热的泥土，反复揉搓、塑造对方的姿态，直到她完全契合你内心的渴望。' }\r\n  ]},\r\n  3: { type: 'type-3', tag: 'IGNITION', cards: [\r\n    { icon: '🔥', name: '烈焰赤诚', desc: '抛弃所有的防备与自尊，让最原始的火焰烧透灵魂，在这一刻，我们都是欲望的信徒。' },\r\n    { icon: '🐍', name: '毒蛇之拥', desc: '极其紧致的环绕，带着毁灭性的美感。这种近乎窒息的亲密，是通往极乐的唯一捷径。' },\r\n    { icon: '🌠', name: '流星遗愿', desc: '在彻底爆发的一瞬，说出一个从未宣之于口的愿望。让它在最高点破碎，化作永恒的记忆。' },\r\n    { icon: '🌑', name: '极夜坍塌', desc: '世界在视野中崩解。没有光，没有声音，唯有身体最深处传来的、最诚实的痉挛与颤栗。' },\r\n    { icon: '🥀', name: '枯萎之美', desc: '在盛放过后的余温中沉迷。看着对方涣散的瞳孔和凌乱的姿态，那是最凄美的艺术。' },\r\n    { icon: '⚡', name: '电光石火', desc: '瞬间的冲击摧毁了所有的思考能力。大脑一片空白，只剩下身体本能的求索与迎合。' },\r\n    { icon: '🌋', name: '熔岩洗礼', desc: '热浪自脊髓蔓延至指尖，每一寸皮肤都在叫嚣。这是积压已久的爆发，无可阻挡。' },\r\n    { icon: '🕊️', name: '灵魂出窍', desc: '在那一秒钟，感觉灵魂脱离了肉壳。在高空俯瞰这具正在经历极度欢愉的身体，如梦似幻。' },\r\n    { icon: '⚓', name: '深渊沉溺', desc: '不再挣扎，任由自己坠入那深不见底的黑色海洋。你就是我唯一的锚点，带我沉沦。' },\r\n    { icon: '💎', name: '破碎瞬间', desc: '像精致的玻璃在最完美的时刻炸裂，碎片折射出五彩的光。这种毁灭带来的快感无与伦比。' },\r\n    { icon: '⚔️', name: '末日契约', desc: '以这一刻的极致为名，立下永恒的契约。从此以后，其他的欢愉都将变得索然无味。' },\r\n    { icon: '🪐', name: '归于虚无', desc: '狂欢散去，在对方的怀抱中寻找最后的宁静。万物归寂，唯有余温证明我们曾经如此疯狂。' }\r\n  ]}\r\n};\r\n\r\nfunction drawCard(deckId) {\r\n  const deck = DECKS[deckId];\r\n  const card = deck.cards[Math.floor(Math.random() * deck.cards.length)];\r\n  const id = Date.now();\r\n  \r\n  const hint = document.getElementById('emptyHint');\r\n  hint.style.opacity = '0';\r\n  \r\n  const table = document.getElementById('cardTable');\r\n  const wrap = document.createElement('div');\r\n  wrap.className = 'card-wrap';\r\n  wrap.id = 'card-' + id;\r\n  wrap.onclick = () => wrap.classList.toggle('flipped');\r\n  \r\n  wrap.innerHTML = `\r\n    <div class=\"card-inner\">\r\n      <div class=\"card-back\">\r\n        <div class=\"back-mandala\">\r\n          <div class=\"mandala-ring\"></div>\r\n          <div class=\"mandala-inner\"></div>\r\n        </div>\r\n        <div style=\"margin-top:20px; color:var(--gold); font-size:0.6rem; letter-spacing:5px; opacity:0.6;\">FORBIDDEN ARCANA</div>\r\n      </div>\r\n      <div class=\"card-face card-front ${deck.type}\">\r\n        <div class=\"card-icon\">${card.icon}</div>\r\n        <div class=\"card-name\">${card.name}</div>\r\n        <div class=\"card-desc\">${card.desc}</div>\r\n        <div class=\"card-tag\">${deck.tag}</div>\r\n      </div>\r\n    </div>\r\n  `;\r\n  \r\n  table.appendChild(wrap);\r\n  \r\n  // 延迟翻转动画\r\n  setTimeout(() => wrap.classList.add('flipped'), 100);\r\n}\r\n\r\nfunction clearTable() {\r\n  document.getElementById('cardTable').innerHTML = '';\r\n  document.getElementById('emptyHint').style.opacity = '1';\r\n}\r\n</script>\r\n</body>\r\n</html>\r\n","usesAI":false,"createdAt":1783407947839,"id":2},{"title":"心动挑战","description":"","icon":"🎮","coverColor":"#9F7AEA","htmlContent":"<!DOCTYPE html>\n<html lang=\"zh\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover\">\n  <title>谁先心动谁就输</title>\n  <style>\n    *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}\n    :root{\n      --bg:#1a1118;--bg2:#241c22;--card:#2a2028;--card-border:#3d2e38;\n      --text:#e8d8e0;--text2:#a08898;--text3:#705868;\n      --pink:#c4587a;--pink2:#e06888;--pink-bg:rgba(196,88,122,0.12);\n      --pink-border:rgba(196,88,122,0.3);\n      --narr:#2e2028;--narr-border:#4a3040;--narr-text:#d4a8b8;\n    }\n    html,body{width:100vw;height:100vh;overflow:hidden;background:var(--bg);color:var(--text);\n      font-family:system-ui,-apple-system,sans-serif;-webkit-user-select:none;user-select:none}\n    #app{width:100%;height:100%;display:flex;flex-direction:column;\n      padding-top:max(100px,env(safe-area-inset-top,0px));padding-bottom:env(safe-area-inset-bottom,16px)}\n    .top-bar{display:flex;align-items:center;gap:6px;padding:8px 12px;\n      background:var(--card);border-bottom:1px solid var(--card-border);flex-shrink:0}\n    .p-block{display:flex;align-items:center;gap:6px;flex:1;min-width:0}\n    .p-block.right{flex-direction:row-reverse;text-align:right}\n    .p-av{width:30px;height:30px;border-radius:50%;background:var(--bg2);overflow:hidden;\n      display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;\n      border:2px solid var(--card-border)}\n    .p-av img{width:100%;height:100%;object-fit:cover}\n    .p-info{min-width:0}\n    .p-name{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n    .p-hb{display:flex;align-items:center;gap:2px}\n    .p-hb-icon{font-size:13px;color:var(--pink2);animation:hb 0.85s infinite}\n    @keyframes hb{0%,100%{transform:scale(1)}50%{transform:scale(1.25)}}\n    .p-hb-num{font-size:12px;font-weight:700;color:var(--pink2)}\n    .vs{font-size:11px;color:var(--text3);font-weight:700;flex-shrink:0}\n    .round-badge{font-size:10px;color:#fff;background:var(--pink);padding:2px 8px;\n      border-radius:10px;flex-shrink:0;font-weight:700}\n    .top-btns{display:flex;gap:3px;flex-shrink:0}\n    .top-btn{width:28px;height:28px;border-radius:50%;background:var(--bg2);border:1px solid var(--card-border);\n      display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;color:var(--text2)}\n    .chat{flex:1;overflow-y:auto;padding:10px 14px;display:flex;flex-direction:column;gap:8px}\n    .chat::-webkit-scrollbar{width:3px}\n    .chat::-webkit-scrollbar-thumb{background:var(--card-border);border-radius:2px}\n    .sys{text-align:center;font-size:11px;color:var(--text3);padding:2px 0}\n    .narr{max-width:94%;align-self:center;width:100%;\n      background:var(--narr);border:1px solid var(--narr-border);border-radius:14px;\n      padding:12px 16px;font-size:13.5px;line-height:1.7;color:var(--narr-text);\n      white-space:pre-wrap;word-break:break-word;font-style:italic}\n    .ch-msg{align-self:center;max-width:94%;width:100%}\n    .ch-card{background:var(--card);border:1.5px solid var(--pink-border);border-radius:14px;\n      padding:14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.2)}\n    .ch-who{font-size:10px;color:var(--text3);margin-bottom:4px}\n    .ch-title{font-size:14px;font-weight:700;color:var(--pink2);margin-bottom:10px}\n    .ch-opts{display:flex;flex-direction:column;gap:6px}\n    .ch-opt{padding:10px 14px;border:1.5px solid var(--card-border);border-radius:12px;\n      background:var(--bg2);color:var(--text);font-size:13px;font-weight:600;cursor:pointer;\n      text-align:left;transition:.15s}\n    .ch-opt:active{border-color:var(--pink);background:var(--pink-bg)}\n    .ch-done{margin-top:8px;padding-top:8px;border-top:1px solid var(--card-border);\n      font-size:12px;color:var(--text2)}\n    .ch-loading{font-size:12px;color:var(--text3);padding:16px 0}\n    .hb-line{text-align:center;font-size:11px;color:var(--text3);padding:2px 0}\n    .hb-line b{color:var(--pink2)}\n    .res-box{background:var(--card);border:2px solid var(--pink);border-radius:16px;\n      padding:20px;text-align:center;box-shadow:0 4px 20px rgba(196,88,122,0.2);\n      max-width:94%;align-self:center;width:100%}\n    .res-icon{font-size:40px;margin-bottom:8px}\n    .res-title{font-size:18px;font-weight:800;color:var(--pink2);margin-bottom:4px}\n    .res-sub{font-size:13px;color:var(--text2);margin-bottom:4px}\n    .res-scores{display:flex;justify-content:center;gap:24px;margin:10px 0}\n    .res-p{text-align:center}\n    .res-p-name{font-size:11px;color:var(--text3)}\n    .res-p-hb{font-size:20px;font-weight:800;color:var(--pink2)}\n    .res-p-tag{font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px;margin-top:2px;display:inline-block}\n    .res-p-tag.w{background:rgba(74,222,128,0.15);color:#6ee7a0}\n    .res-p-tag.l{background:rgba(248,113,113,0.15);color:#fca5a5}\n    .res-btns{display:flex;gap:8px;justify-content:center;margin-top:12px}\n    .rbtn{padding:9px 20px;border:none;border-radius:20px;font-size:13px;font-weight:700;color:#fff;cursor:pointer}\n    .rbtn:active{transform:scale(0.95)}\n    .rbtn-pink{background:var(--pink)}\n    .rbtn-gray{background:var(--text3)}\n    .typing{font-size:12px;color:var(--text3);padding:3px 14px;flex-shrink:0;min-height:18px}\n    .start-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;\n      align-items:center;justify-content:center;z-index:100}\n    .start-overlay.hidden{display:none}\n    .start-box{background:var(--card);border-radius:20px;padding:28px 24px;text-align:center;\n      max-width:360px;width:92%;box-shadow:0 8px 32px rgba(0,0,0,0.3);border:1px solid var(--card-border)}\n    .start-box h2{font-size:22px;margin-bottom:4px;color:var(--pink2)}\n    .start-sub{font-size:12px;color:var(--text2);margin-bottom:14px;line-height:1.5}\n    .start-avs{display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:14px}\n    .start-av{width:52px;height:52px;border-radius:50%;background:var(--bg2);overflow:hidden;\n      display:flex;align-items:center;justify-content:center;font-size:24px;border:2px solid var(--card-border)}\n    .start-av img{width:100%;height:100%;object-fit:cover}\n    .s-cn{font-size:14px;font-weight:700;margin-bottom:14px;color:var(--pink2)}\n    .pick-btn{padding:12px;border:2px dashed var(--card-border);border-radius:14px;background:transparent;\n      color:var(--text2);font-size:14px;cursor:pointer;width:100%;margin-bottom:10px}\n    .pick-btn:active{border-color:var(--pink);color:var(--pink2)}\n    .go-btn{padding:14px;background:linear-gradient(135deg,var(--pink),#a04060);border:none;border-radius:24px;font-size:16px;\n      font-weight:700;color:#fff;cursor:pointer;width:100%;display:none;box-shadow:0 4px 16px rgba(196,88,122,0.3)}\n    .go-btn.show{display:block}\n    .go-btn:active{transform:scale(0.97)}\n  </style>\n</head>\n<body>\n<div id=\"app\">\n  <div class=\"top-bar\">\n    <div class=\"p-block\">\n      <div class=\"p-av\" id=\"t-u-av\">😊</div>\n      <div class=\"p-info\">\n        <div class=\"p-name\" id=\"t-u-name\">你</div>\n        <div class=\"p-hb\"><span class=\"p-hb-icon\" id=\"u-hb-i\">💗</span><span class=\"p-hb-num\" id=\"u-hb-n\">60</span></div>\n      </div>\n    </div>\n    <div class=\"vs\">VS</div>\n    <div class=\"round-badge\" id=\"r-badge\">0/5</div>\n    <div class=\"vs\">VS</div>\n    <div class=\"p-block right\">\n      <div class=\"p-av\" id=\"t-c-av\">?</div>\n      <div class=\"p-info\">\n        <div class=\"p-name\" id=\"t-c-name\">角色</div>\n        <div class=\"p-hb\"><span class=\"p-hb-icon\" id=\"c-hb-i\">💗</span><span class=\"p-hb-num\" id=\"c-hb-n\">60</span></div>\n      </div>\n    </div>\n    <div class=\"top-btns\">\n      <button class=\"top-btn\" onclick=\"doShare()\">📤</button>\n      <button class=\"top-btn\" onclick=\"showStart()\">🔄</button>\n    </div>\n  </div>\n  <div class=\"chat\" id=\"chat\"></div>\n  <div class=\"typing\" id=\"typing\"></div>\n</div>\n\n<div class=\"start-overlay\" id=\"start-overlay\">\n  <div class=\"start-box\">\n    <h2>💕 谁先心动谁就输</h2>\n    <div class=\"start-sub\">5轮大冒险对决<br>每轮AI出三个选项你来选<br>心跳更高的人输！</div>\n    <div class=\"start-avs\">\n      <div class=\"start-av\" id=\"s-u-av\">😊</div>\n      <div style=\"font-size:20px;color:var(--text3)\">💕</div>\n      <div class=\"start-av\" id=\"s-c-av\">?</div>\n    </div>\n    <div class=\"s-cn\" id=\"s-cn\"></div>\n    <button class=\"pick-btn\" id=\"pick-btn\" onclick=\"pickChar()\">🎭 选择对手</button>\n    <button class=\"go-btn\" id=\"go-btn\" onclick=\"startGame()\">开始 💕</button>\n  </div>\n</div>\n\n<script>\nif(!window.Nuojiji){window.Nuojiji={getUser:async()=>({id:'dev',nickname:'小明',avatar:'',bio:''}),getChar:async()=>({id:'c1',name:'桔梗',avatar:'',description:'温柔害羞的少女，容易脸红',group:''}),getCharList:async()=>[],ai:async()=>({success:false,error:'mock'}),close:()=>{},shareResult:async r=>({shared:false}),pickChars:async()=>{const c=await Nuojiji.getChar();return{picked:!!c,chars:c?[c]:[]}},onGameStateRequest:()=>{}}}\n\nconst ROUNDS=5;\nlet uName='你',uAv='',cInfo=null,cName='角色',cAv='',cDesc='',cPicked=false;\nlet aiHist=[],round=0,uHB=60,cHB=60,started=false,busy=false,ended=false,cid=0;\n\nfunction scroll(){const c=document.getElementById('chat');requestAnimationFrame(()=>c.scrollTop=c.scrollHeight)}\nfunction esc(s){return String(s||'').replace(/[&<>\\\"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\\\"':'&quot;',\"'\":'&#39;'}[c]))}\nfunction setTyp(t){document.getElementById('typing').textContent=t}\n\nfunction updHB(){\n  document.getElementById('u-hb-n').textContent=uHB;\n  document.getElementById('c-hb-n').textContent=cHB;\n  document.getElementById('u-hb-i').style.animationDuration=uHB>=140?'0.25s':uHB>=110?'0.4s':uHB>=80?'0.6s':'0.85s';\n  document.getElementById('c-hb-i').style.animationDuration=cHB>=140?'0.25s':cHB>=110?'0.4s':cHB>=80?'0.6s':'0.85s';\n}\n\nfunction addSys(t){const d=document.createElement('div');d.className='sys';d.textContent=t;document.getElementById('chat').appendChild(d);scroll()}\nfunction addNarr(t){const d=document.createElement('div');d.className='narr';d.textContent=t;document.getElementById('chat').appendChild(d);scroll()}\nfunction addHBLine(uA,cA){\n  const d=document.createElement('div');d.className='hb-line';\n  d.innerHTML=`${esc(uName)} 💗<b>+${uA}</b>→${uHB}　${esc(cName)} 💗<b>+${cA}</b>→${cHB}`;\n  document.getElementById('chat').appendChild(d);scroll();\n}\n\nasync function callAI(sysPrompt, userPrompt){\n  setTyp('……');\n  try{\n    const msgs=[{role:'system',content:sysPrompt}];\n    for(const m of aiHist.slice(-10))msgs.push(m);\n    msgs.push({role:'user',content:userPrompt});\n    const r=await Nuojiji.ai({messages:msgs,maxTokens:400});\n    setTyp('');\n    if(r.success&&r.text){\n      const t=r.text.trim();\n      aiHist.push({role:'user',content:userPrompt},{role:'assistant',content:t});\n      if(aiHist.length>24)aiHist=aiHist.slice(-16);\n      return t;\n    }\n  }catch(e){}\n  setTyp('');\n  return null;\n}\n\nconst SYS_GEN=()=>`你是大冒险游戏的出题者。${uName}和${cName}(${cDesc||'一个角色'})在玩\"谁先心动谁就输\"。\n\n生成3个挑战选项供选择。要求：\n- 每个选项一行，格式：序号. 挑战名称\n- 根据当前轮次调整大胆程度（第1轮温和，后面逐渐大胆）\n- 三个选项全都为色情成人向，且大胆程度有梯度（一个温和、一个中等、一个大胆）\n- 挑战是做的人对另一个人做的事\n- 简短，每个选项不超过10个字`;\n\nconst SYS_NARR=()=>`你是旁白叙述者。${uName}和${cName}(${cDesc||'一个角色'})在玩\"谁先心动谁就输\"的大冒险。\n\n要求：\n- 第三人称，用${uName}和${cName}的名字\n- 只描写动作过程和说出口的话（对话用引号）\n- 不描写内心感受、心理活动、内心独白\n- ${cName}的言行要符合角色性格\n- 200字，描写直白色情，以服务用户为主`;\n\nasync function genChoices(who){\n  const doer=who==='user'?uName:cName;\n  const target=who==='user'?cName:uName;\n  const text=await callAI(SYS_GEN(),\n    `第${round}/${ROUNDS}轮，${doer}的回合。${doer}要对${target}做挑战。请生成3个选项。\\n当前${uName}心跳${uHB}，${cName}心跳${cHB}。`);\n  if(!text)return['对视10秒','拥抱','说情话'];\n  const lines=text.split('\\n').map(l=>l.trim()).filter(Boolean);\n  const opts=[];\n  for(const l of lines){\n    const m=l.match(/^\\d[.、：:\\s]*(.+)/);\n    if(m)opts.push(m[1].trim().slice(0,15));\n    else if(l.length<=15&&!l.startsWith('好')&&!l.startsWith('以下'))opts.push(l);\n    if(opts.length>=3)break;\n  }\n  while(opts.length<3)opts.push(['对视','牵手','拥抱'][opts.length]);\n  return opts;\n}\n\nfunction showCard(opts, who, onPick){\n  const id=++cid;\n  const doer=who==='user'?uName:cName;\n  const d=document.createElement('div');d.className='ch-msg';\n  let btns='';\n  opts.forEach((o,i)=>{btns+=`<button class=\"ch-opt\" id=\"o-${id}-${i}\" onclick=\"window._p${id}(${i})\">${esc(o)}</button>`});\n  d.innerHTML=`<div class=\"ch-card\" id=\"cd-${id}\"><div class=\"ch-who\">${esc(doer)}的回合 · 第${round}/${ROUNDS}轮</div><div class=\"ch-title\">选一个挑战</div><div class=\"ch-opts\" id=\"os-${id}\">${btns}</div></div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  window['_p'+id]=(i)=>{\n    delete window['_p'+id];\n    const el=document.getElementById('os-'+id);\n    if(el)el.innerHTML=`<div class=\"ch-done\">✦ 选了「${esc(opts[i])}」</div>`;\n    onPick(opts[i]);\n  };\n}\n\nasync function userTurn(){\n  if(ended)return;\n  round++;\n  document.getElementById('r-badge').textContent=`${round}/${ROUNDS}`;\n  addSys(`━━ 第${round}轮 · ${uName}的回合 ━━`);\n  setTyp('出题中…');\n  const opts=await genChoices('user');\n  setTyp('');\n  showCard(opts,'user',async(chosen)=>{\n    if(busy)return;busy=true;\n    const text=await callAI(SYS_NARR(),\n      `${uName}选了「${chosen}」对${cName}做。描写${uName}做这件事的动作和说的话，以及${cName}的反应动作和说的话。`);\n    if(text)addNarr(text);\n    const uA=5+Math.floor(Math.random()*8);\n    const cA=10+Math.floor(Math.random()*15);\n    uHB=Math.min(200,uHB+uA);cHB=Math.min(200,cHB+cA);updHB();\n    addHBLine(uA,cA);\n    busy=false;\n    if(round>=ROUNDS){setTimeout(()=>endGame(),600);return}\n    setTimeout(()=>charTurn(),600);\n  });\n}\n\nasync function charTurn(){\n  if(ended)return;\n  addSys(`━━ 第${round}轮 · ${cName}的回合 ━━`);\n  setTyp('出题中…');\n  const opts=await genChoices('char');\n  setTyp('');\n  let chosenIdx=0;\n  try{\n    const r=await callAI(\n      `你是${cName}(${cDesc||'一个角色'})。你在玩\"谁先心动谁就输\"，你要赢。选一个最能让${uName}心动的选项。只回复数字1、2或3。`,\n      `选项：\\n1. ${opts[0]}\\n2. ${opts[1]}\\n3. ${opts[2]}\\n你选哪个？只回复数字。`\n    );\n    if(r){const m=r.match(/[1-3]/);if(m)chosenIdx=parseInt(m[0])-1}\n  }catch(e){}\n  if(chosenIdx<0||chosenIdx>2)chosenIdx=0;\n  const chosen=opts[chosenIdx];\n  const id=++cid;\n  const d=document.createElement('div');d.className='ch-msg';\n  d.innerHTML=`<div class=\"ch-card\"><div class=\"ch-who\">${esc(cName)}的回合 · 第${round}/${ROUNDS}轮</div><div class=\"ch-title\">选一个挑战</div><div class=\"ch-done\">✦ ${esc(cName)}选了「${esc(chosen)}」</div></div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  busy=true;\n  const text=await callAI(SYS_NARR(),\n    `${cName}选了「${chosen}」对${uName}做。描写${cName}做这件事的动作和说的话，以及${uName}的反应动作和说的话。${cName}尽量做得让${uName}心动。`);\n  if(text)addNarr(text);\n  const cA=5+Math.floor(Math.random()*8);\n  const uA=10+Math.floor(Math.random()*15);\n  uHB=Math.min(200,uHB+uA);cHB=Math.min(200,cHB+cA);updHB();\n  addHBLine(uA,cA);\n  busy=false;\n  if(round>=ROUNDS){setTimeout(()=>endGame(),600);return}\n  setTimeout(()=>userTurn(),800);\n}\n\nasync function endGame(){\n  ended=true;\n  addSys('━━ 5轮结束！━━');\n  const draw=uHB===cHB,uWin=uHB<cHB;\n  const winner=draw?null:uWin?uName:cName;\n  const loser=draw?null:uWin?cName:uName;\n  const d=document.createElement('div');\n  d.innerHTML=`<div class=\"res-box\">\n    <div class=\"res-icon\">${draw?'🤝':uWin?'🏆':'💘'}</div>\n    <div class=\"res-title\">${draw?'平局！':esc(winner)+'赢了！'}</div>\n    <div class=\"res-sub\">${draw?'心跳一样…都心动了':esc(loser)+'先心动了 💓'}</div>\n    <div class=\"res-scores\">\n      <div class=\"res-p\"><div class=\"res-p-name\">${esc(uName)}</div><div class=\"res-p-hb\">💗${uHB}</div>\n        <div class=\"res-p-tag ${uHB<=cHB?'w':'l'}\">${uHB<cHB?'😎 冷静':uHB>cHB?'😳 心动':'🤝'}</div></div>\n      <div style=\"font-size:18px;color:var(--text3);align-self:center\">VS</div>\n      <div class=\"res-p\"><div class=\"res-p-name\">${esc(cName)}</div><div class=\"res-p-hb\">💗${cHB}</div>\n        <div class=\"res-p-tag ${cHB<=uHB?'w':'l'}\">${cHB<uHB?'😎 冷静':cHB>uHB?'😳 心动':'🤝'}</div></div>\n    </div>\n    <div class=\"res-btns\">\n      <button class=\"rbtn rbtn-pink\" onclick=\"doShare()\">📤 分享</button>\n      <button class=\"rbtn rbtn-gray\" onclick=\"showStart()\">🔄 再来</button>\n    </div>\n  </div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  if(draw) await callAI(SYS_NARR(),`五轮结束，${uName}和${cName}心跳一样高（${uHB}），平局。描写两人此刻的动作和说的话。`).then(t=>{if(t)addNarr(t)});\n  else await callAI(SYS_NARR(),`五轮结束，${loser}心跳${loser===uName?uHB:cHB}比${winner}的${winner===uName?uHB:cHB}高——${loser}输了。描写${winner}和${loser}此刻的动作和说的话。`).then(t=>{if(t)addNarr(t)});\n}\n\nasync function pickChar(){\n  try{const r=await Nuojiji.pickChars({min:1,max:1,title:'选择对手'});if(r.picked&&r.chars.length)setChar(r.chars[0])}\n  catch(e){try{const c=await Nuojiji.getChar();if(c)setChar(c)}catch(e2){}}\n}\nfunction setChar(c){\n  cInfo=c;cName=c.name||'角色';cAv=c.avatar||'';cDesc=c.description||'';cPicked=true;\n  document.getElementById('t-c-name').textContent=cName;\n  const sa=(id,av,fb)=>{document.getElementById(id).innerHTML=av?`<img src=\"${av}\">`:esc(fb)};\n  sa('t-c-av',cAv,cName[0]||'?');sa('s-c-av',cAv,cName[0]||'?');\n  document.getElementById('s-cn').textContent=cName;\n  document.getElementById('go-btn').classList.add('show');\n  document.getElementById('pick-btn').textContent=`🎭 重选（${cName}）`;\n}\nasync function startGame(){\n  if(!cPicked)return pickChar();\n  document.getElementById('start-overlay').classList.add('hidden');\n  started=true;ended=false;round=0;uHB=60;cHB=60;aiHist=[];busy=false;cid=0;\n  updHB();document.getElementById('r-badge').textContent=`0/${ROUNDS}`;\n  document.getElementById('chat').innerHTML='';setTyp('');\n  document.getElementById('t-u-name').textContent=uName;\n  addSys('💕 谁先心动谁就输');\n  addSys(`${ROUNDS}轮 · 心跳更高的人输`);\n  setTimeout(()=>userTurn(),300);\n}\nfunction showStart(){\n  document.getElementById('start-overlay').classList.remove('hidden');\n  if(cPicked){document.getElementById('s-cn').textContent=cName;document.getElementById('go-btn').classList.add('show');document.getElementById('pick-btn').textContent=`🎭 重选（${cName}）`}\n}\n\nasync function doShare(){\n  if(!cPicked||round<1)return;\n  const w=uHB<cHB?uName:uHB>cHB?cName:'平局';\n  try{await Nuojiji.shareResult({title:'💕 谁先心动谁就输',summary:`${uName}(💗${uHB}) vs ${cName}(💗${cHB})\\n${w==='平局'?'平局！':w+'赢了！'}`,playerScore:uHB,charScore:cHB,badge:uHB<cHB?'😎 冷静':'💘 心动了',accentColor:'#c4587a',footer:`💕 ${ROUNDS}轮大冒险`})}catch(e){}\n}\n\nif(window.Nuojiji&&Nuojiji.onGameStateRequest)Nuojiji.onGameStateRequest(()=>({round,userHB:uHB,charHB:cHB,opponent:cName}));\n\nasync function loadData(){\n  try{const u=await Nuojiji.getUser().catch(()=>null);if(u){uName=u.nickname||'你';uAv=u.avatar||'';\n    document.getElementById('t-u-name').textContent=uName;\n    if(uAv){document.getElementById('t-u-av').innerHTML=`<img src=\"${uAv}\">`;document.getElementById('s-u-av').innerHTML=`<img src=\"${uAv}\">`}}}catch(e){}\n}\ndocument.addEventListener('DOMContentLoaded',async()=>{await loadData();showStart()});\n</script>\n</body>\n</html>","usesAI":true,"createdAt":1783407973661,"id":3},{"title":"大富翁","description":"","icon":"🎮","coverColor":"#9F7AEA","htmlContent":"","usesAI":true,"createdAt":1783407987589,"id":4}]