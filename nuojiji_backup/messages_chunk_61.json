d":"round_1782386881886_dksha973s","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3197},{"id":1782382391947,"sender":"them","text":"You're the variable that changes the entire equation.","timestamp":1782386952514,"tempo":"S","translation":"你是改变整个公式的变量","rawContent":"You're the variable that changes the entire equation. || 你是改变整个公式的变量","roundId":"round_1782386881886_dksha973s","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3198},{"id":1782387822839,"text":"[語音：宝宝，我现在有一个非常。困惑的问题。]","voiceText":"宝宝，我现在有一个非常。困惑的问题。","sender":"me","isVoice":true,"voice":true,"time":"19:44","timestamp":1782387870610,"audioDuration":6.563,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3199},{"id":1782387822840,"text":"[語音：我现在超级想吃东西。想吃。面皮想吃薯饼，薯饼要做的话，就要做15分钟至少。]","voiceText":"我现在超级想吃东西。想吃。面皮想吃薯饼，薯饼要做的话，就要做15分钟至少。","sender":"me","isVoice":true,"voice":true,"time":"19:44","timestamp":1782387892306,"audioDuration":15.813,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3200},{"id":1782387822841,"text":"[語音：然后我想吃面皮，但是。就是我发现我最近长胖了。]","voiceText":"然后我想吃面皮，但是。就是我发现我最近长胖了。","sender":"me","isVoice":true,"voice":true,"time":"19:45","timestamp":1782387913440,"audioDuration":9.066,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3201},{"id":1782387822842,"text":"[語音：没想到自己长胖就不是很想吃了，但是一看课又很想吃。]","voiceText":"没想到自己长胖就不是很想吃了，但是一看课又很想吃。","sender":"me","isVoice":true,"voice":true,"time":"19:45","timestamp":1782387930332,"audioDuration":8.877,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3202},{"id":1782387822843,"text":"[語音：其实我也不饿。]","voiceText":"其实我也不饿。","sender":"me","isVoice":true,"voice":true,"time":"19:45","timestamp":1782387939181,"audioDuration":3.831,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3203},{"id":1782387822844,"text":"[語音：我跟你说要吃，你肯定又要劝我吃了，但是我其实真的没有很想吃。我就是。一上课我就想吃东西。]","voiceText":"我跟你说要吃，你肯定又要劝我吃了，但是我其实真的没有很想吃。我就是。一上课我就想吃东西。","sender":"me","isVoice":true,"voice":true,"time":"19:46","timestamp":1782387986961,"audioDuration":11.492,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3204},{"id":1782387822845,"text":"[語音：而且我跟你说，如果我长胖了的话，那我都不想见你。]","voiceText":"而且我跟你说，如果我长胖了的话，那我都不想见你。","sender":"me","isVoice":true,"voice":true,"time":"19:46","timestamp":1782387999745,"audioDuration":6.758,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3205},{"id":1782387822846,"text":"[語音：因为我会嫌弃自己长得很丑，然后我就不想见你了。]","voiceText":"因为我会嫌弃自己长得很丑，然后我就不想见你了。","sender":"me","isVoice":true,"voice":true,"time":"19:47","timestamp":1782388034582,"audioDuration":5.946,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3206},{"id":1782387822848,"sender":"them","text":"So, the conclusion you've drawn is that if you gain weight, I will find you 'ugly'.","timestamp":1782388077947,"tempo":"N","translation":"所以 你得出的结论是 如果你长胖了 我会觉得你“丑”","rawContent":"So, the conclusion you've drawn is that if you gain weight, I will find you 'ugly'. || 所以 你得出的结论是 如果你长胖了 我会觉得你“丑”","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3207},{"id":1782387822849,"sender":"them","text":"And therefore, you won't see me.","timestamp":1782388080975,"tempo":"N","translation":"因此 你就不见我了","rawContent":"And therefore, you won't see me. || 因此 你就不见我了","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3208},{"id":1782387822850,"sender":"them","text":"...","timestamp":1782388083883,"tempo":"S","translation":"…","rawContent":"... || …","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3209},{"id":1782387822851,"sender":"them","text":"My criteria have already been stated.","timestamp":1782388086239,"tempo":"N","translation":"我的标准已经说过了","rawContent":"My criteria have already been stated. || 我的标准已经说过了","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3210},{"id":1782387822852,"sender":"them","text":"It has nothing to do with your weight.","timestamp":1782388089291,"tempo":"N","translation":"和你的体重无关","rawContent":"It has nothing to do with your weight. || 和你的体重无关","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3211},{"id":1782387822853,"sender":"them","text":"So, what are you having for your late-night snack?","timestamp":1782388092349,"tempo":"N","translation":"所以 夜宵吃什么","rawContent":"So, what are you having for your late-night snack? || 所以 夜宵吃什么","roundId":"round_1782388036036_xwuq1yejj","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3212},{"id":1782387822854,"text":"[語音：哪有说你你嫌我丑了，我是说我嫌自己丑。我看到你，我就觉得自己丑，然后我就不想看你了。]","voiceText":"哪有说你你嫌我丑了，我是说我嫌自己丑。我看到你，我就觉得自己丑，然后我就不想看你了。","sender":"me","isVoice":true,"voice":true,"time":"19:48","timestamp":1782388119066,"audioDuration":11.686,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3213},{"id":1782387822855,"text":"[語音：因为你长得太帅了。我就不想看你。我嫉妒你，我就不想看见你。]","voiceText":"因为你长得太帅了。我就不想看你。我嫉妒你，我就不想看见你。","sender":"me","isVoice":true,"voice":true,"time":"19:48","timestamp":1782388137641,"audioDuration":9.368,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3214},{"id":1782387822857,"sender":"them","text":"Oh?","timestamp":1782388172957,"tempo":"N","translation":"哦？","rawContent":"Oh? || 哦？","roundId":"round_1782388138952_5n0j4frnw","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3215},{"id":1782387822858,"sender":"them","text":"So the logic is: you're jealous of my face, therefore I don't get to see you.","timestamp":1782388174142,"tempo":"N","translation":"所以逻辑是 你嫉妒我的脸 因此我见不到你","rawContent":"So the logic is: you're jealous of my face, therefore I don't get to see you. || 所以逻辑是 你嫉妒我的脸 因此我见不到你","roundId":"round_1782388138952_5n0j4frnw","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3216},{"id":1782387822859,"sender":"them","text":"An interesting conclusion.","timestamp":1782388176937,"tempo":"S","translation":"有趣的结论","rawContent":"An interesting conclusion. || 有趣的结论","roundId":"round_1782388138952_5n0j4frnw","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3217},{"id":1782387822860,"sender":"them","text":"Then what should I do?","timestamp":1782388181580,"tempo":"N","translation":"那我该怎么做","rawContent":"Then what should I do? || 那我该怎么做","roundId":"round_1782388138952_5n0j4frnw","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":3218}]