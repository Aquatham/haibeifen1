[{"id":"cwt-1782749735877-dfpp","name":"ipod一起听","size":"large","html":"<div class=\"wrap\">\n  <div class=\"head\">\n    <svg class=\"cords\" viewBox=\"0 0 200 110\" preserveAspectRatio=\"none\">\n      <path d=\"M 42 30 Q 10 80 60 95 Q 90 108 100 110\"\n            stroke=\"#b8b8b8\" stroke-width=\"1.4\" fill=\"none\" stroke-linecap=\"round\"/>\n      <path d=\"M 158 30 Q 190 80 140 95 Q 110 108 100 110\"\n            stroke=\"#b8b8b8\" stroke-width=\"1.4\" fill=\"none\" stroke-linecap=\"round\"/>\n    </svg>\n\n    <div class=\"avatars\">\n      <img class=\"av av1\" src=\"{{avatar1}}\" alt=\"\">\n      <img class=\"av av2\" src=\"{{avatar2}}\" alt=\"\">\n    </div>\n\n    <div class=\"together-text\">\n      <span id=\"distText\">查看距離</span>，一起聽了 <span id=\"together\">0 分鐘</span>\n    </div>\n  </div>\n\n  <div class=\"ipod\">\n    <div class=\"screen\">\n      <div class=\"screen-top\">\n        <span>♪ Now Playing</span>\n        <span id=\"batt\">100%</span>\n      </div>\n      <div class=\"np\">\n        <img class=\"cover\" src=\"{{cover}}\" alt=\"\">\n        <div class=\"info\">\n          <div class=\"song\" id=\"song\">歌名</div>\n          <div class=\"artist\" id=\"artist\">歌手</div>\n        </div>\n      </div>\n      <div class=\"bottom-bar\">\n        <span id=\"cur\">00:00</span>\n        <div class=\"bar\"><div class=\"bar-fill\" id=\"fill\"></div></div>\n        <span id=\"dur\">03:30</span>\n      </div>\n    </div>\n\n    <div class=\"wheel\">\n      <div class=\"wheel-label menu\">MENU</div>\n      <div class=\"wheel-btn prev\" id=\"prev\"></div>\n      <div class=\"wheel-btn next\" id=\"next\"></div>\n      <div class=\"wheel-btn play\" id=\"play\"></div>\n      <div class=\"center\" id=\"center\"></div>\n    </div>\n  </div>\n\n  <audio id=\"audio\" loop preload=\"none\"></audio>\n</div>\n\n<script>\nwidget.onReady(async () => {\n  // 讀用戶字段\n  const distText = (await widget.getState('distance_text')) ?? '查看距離';\n  const song = (await widget.getState('song')) ?? '未命名歌曲';\n  const artist = (await widget.getState('artist')) ?? '未知歌手';\n  const audioUrl = (await widget.getState('audio')) ?? '';\n\n  document.getElementById('distText').textContent = distText;\n  document.getElementById('song').textContent = song;\n  document.getElementById('artist').textContent = artist;\n\n  const audio = document.getElementById('audio');\n  if (audioUrl) audio.src = audioUrl;\n\n // ===== 一起聽計時 =====\nconst userStart = (await widget.getState('start_date')) ?? '';\nlet startTs;\n\nif (userStart) {\n  // 用戶填了日期，以用戶填的為準（編輯不影響）\n  const t = new Date(userStart.replace(/-/g, '/')).getTime();\n  startTs = isNaN(t) ? Date.now() : t;\n} else {\n  // 沒填，用首次打開時間\n  startTs = await widget.getState('ipod_start_ts');\n  if (!startTs) {\n    startTs = Date.now();\n    await widget.setState('ipod_start_ts', startTs);\n  }\n  startTs = +startTs;\n}\n\nconst togetherEl = document.getElementById('together');\nfunction fmtTogether() {\n  const sec = Math.floor((Date.now() - startTs) / 1000);\n  if (sec < 60) { togetherEl.textContent = `${sec} 秒`; return; }\n  const d = Math.floor(sec / 86400);\n  const h = Math.floor((sec % 86400) / 3600);\n  const m = Math.floor((sec % 3600) / 60);\n  if (d > 0) togetherEl.textContent = `${d} 天 ${h} 小時`;\n  else if (h > 0) togetherEl.textContent = `${h} 小時 ${m} 分`;\n  else togetherEl.textContent = `${m} 分鐘`;\n}\nfmtTogether();\nsetInterval(fmtTogether, 1000);\n\n  // ===== 進度 =====\n  const fill = document.getElementById('fill');\n  const curEl = document.getElementById('cur');\n  const durEl = document.getElementById('dur');\n  let fakeCur = 0, fakeDur = 210, playing = false;\n  const pad = n => String(n).padStart(2,'0');\n  const fmtTime = s => { s = Math.max(0, Math.floor(s)); return pad(Math.floor(s/60))+':'+pad(s%60); };\n\n  function render() {\n    const hasAudio = audioUrl && audio.duration;\n    const cur = hasAudio ? audio.currentTime : fakeCur;\n    const dur = hasAudio ? audio.duration : fakeDur;\n    fill.style.width = (cur/dur*100) + '%';\n    curEl.textContent = fmtTime(cur);\n    durEl.textContent = fmtTime(dur);\n  }\n  setInterval(() => {\n    if (playing && (audio.paused || !audio.duration)) fakeCur = (fakeCur+1) % fakeDur;\n    render();\n  }, 1000);\n  render();\n\n  function toggle() {\n    playing = !playing;\n    if (audioUrl) {\n      playing ? audio.play().catch(()=>{}) : audio.pause();\n    }\n  }\n  document.getElementById('center').onclick = toggle;\n  document.getElementById('play').onclick = toggle;\n  document.getElementById('prev').onclick = () => { fakeCur = 0; if(audioUrl) try{audio.currentTime=0}catch(e){} render(); };\n  document.getElementById('next').onclick = () => { fakeCur = 0; if(audioUrl) try{audio.currentTime=0}catch(e){} render(); };\n\n  // 假電量\n  const battEl = document.getElementById('batt');\n  const updBatt = () => battEl.textContent = (80 + Math.floor(Math.random()*20)) + '%';\n  updBatt();\n  setInterval(updBatt, 60000);\n});\n</script>","css":"* { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml, body {\n  width: 100%;\n  height: 100%;\n  background: transparent;\n  font-family: -apple-system, \"PingFang SC\", \"Helvetica Neue\", sans-serif;\n  overflow: hidden;\n}\n\n.wrap {\n  width: 100%;\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 4px;\n}\n\n/* ========== 頭像 + 耳機線 ========== */\n.head {\n  position: relative;\n  width: 100%;\n  height: 32%;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: flex-start;\n  padding-top: 2px;\n}\n\n.avatars {\n  display: flex;\n  gap: 0;\n  z-index: 2;\n  position: relative;\n}\n\n.av {\n  width: 60px;\n  height: 60px;\n  border-radius: 50%;\n  object-fit: cover;\n  border: 2.5px solid #fff;\n  box-shadow: 0 2px 8px rgba(0,0,0,.18);\n  background: #eee;\n}\n\n/* 兩個頭像互相疊壓 */\n.av1 { margin-right: -10px; z-index: 2; }\n.av2 { z-index: 1; }\n\n.cords {\n  position: absolute;\n  top: 0;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 160px;\n  height: 100%;\n  pointer-events: none;\n  z-index: 1;\n}\n\n.together-text {\n  position: absolute;\n  bottom: 0;\n  left: 50%;\n  transform: translateX(-50%);\n  font-size: 11px;\n  color: #888;\n  white-space: nowrap;\n  letter-spacing: .3px;\n  z-index: 3;\n  text-shadow: 0 1px 2px rgba(255,255,255,.7);\n}\n.together-text #together {\n  color: #ff5a7a;\n  font-weight: 700;\n}\n\n/* ========== iPod 本體（豎長方形） ========== */\n.ipod {\n  flex: 1;\n  width: 68%;\n  max-width: 200px;\n  background: #fff;\n  border-radius: 14px;\n  padding: 10px 9px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,1),\n    inset 0 -2px 6px rgba(0,0,0,.04),\n    0 6px 18px rgba(0,0,0,.18),\n    0 1px 3px rgba(0,0,0,.08);\n  border: 1px solid rgba(0,0,0,.06);\n}\n\n.screen {\n  background: linear-gradient(180deg, #f4f6f8 0%, #e7ecef 100%);\n  border-radius: 3px;\n  padding: 4px 6px;\n  flex: 0 0 42%;\n  display: flex;\n  flex-direction: column;\n  gap: 3px;\n  box-shadow:\n    inset 0 1px 3px rgba(0,0,0,.18),\n    inset 0 -1px 0 rgba(255,255,255,.6);\n  color: #333;\n  border: 1px solid #c8ccd0;\n}\n\n.screen-top {\n  display: flex;\n  justify-content: space-between;\n  font-size: 8px;\n  font-weight: 700;\n  border-bottom: 1px solid rgba(0,0,0,.12);\n  padding-bottom: 2px;\n  color: #444;\n}\n\n.np {\n  display: flex;\n  gap: 6px;\n  flex: 1;\n  align-items: center;\n  min-height: 0;\n}\n\n.cover {\n  width: 40px;\n  height: 40px;\n  border-radius: 2px;\n  object-fit: cover;\n  box-shadow: 0 1px 3px rgba(0,0,0,.3);\n  background: #888;\n  flex-shrink: 0;\n}\n\n.info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }\n.song { font-size: 10px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.artist { font-size: 8px; color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n\n.bottom-bar { display: flex; align-items: center; gap: 4px; font-size: 7px; color: #555; }\n.bar { flex: 1; height: 3px; background: rgba(0,0,0,.1); border-radius: 2px; overflow: hidden; }\n.bar-fill { height: 100%; width: 30%; background: linear-gradient(90deg, #4a9eff, #2b7de8); border-radius: 2px; transition: width .3s linear; }\n\n.wheel {\n  flex: 1;\n  position: relative;\n  aspect-ratio: 1;\n  margin: 0 auto;\n  max-height: 100%;\n  background: radial-gradient(circle at 30% 25%, #ffffff 0%, #f0f0f2 50%, #d8d8dc 100%);\n  border-radius: 50%;\n  box-shadow:\n    inset 0 2px 4px rgba(255,255,255,1),\n    inset 0 -3px 6px rgba(0,0,0,.08),\n    0 1px 3px rgba(0,0,0,.12);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.wheel-label.menu {\n  position: absolute; top: 7%;\n  font-size: 8px; font-weight: 700;\n  color: #888; letter-spacing: 1px;\n  user-select: none;\n}\n\n.wheel-btn {\n  position: absolute;\n  width: 18%; height: 18%;\n  background-repeat: no-repeat;\n  background-position: center;\n  background-size: 75% 75%;\n  cursor: pointer;\n  opacity: .55;\n  transition: opacity .15s, transform .1s;\n}\n.wheel-btn:active { transform: scale(.88); opacity: .9; }\n\n.wheel-btn.prev {\n  left: 8%;\n  background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%23555' d='M6 6h2v12H6zm3.5 6l8.5 6V6z'/></svg>\");\n}\n.wheel-btn.next {\n  right: 8%;\n  background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%23555' d='M16 6h2v12h-2zM6 18l8.5-6L6 6z'/></svg>\");\n}\n.wheel-btn.play {\n  bottom: 7%;\n  background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%23555' d='M4 5h3v14H4zm6 0v14l11-7z'/></svg>\");\n}\n\n.center {\n  width: 38%; height: 38%;\n  border-radius: 50%;\n  background: radial-gradient(circle at 35% 30%, #ffffff 0%, #f5f5f7 60%, #e0e0e4 100%);\n  box-shadow:\n    inset 0 1px 2px rgba(255,255,255,1),\n    inset 0 -1px 2px rgba(0,0,0,.08),\n    0 1px 3px rgba(0,0,0,.18);\n  cursor: pointer;\n  transition: transform .1s;\n}\n.center:active { transform: scale(.94); }","images":{"avatar1":"","avatar2":"","cover":""},"userFields":[{"key":"distance_text","type":"text","label":"距离"},{"key":"song","type":"text","label":"歌名"},{"key":"artist","type":"text","label":"歌手"},{"key":"audio","type":"text","label":"音频url（可选）"},{"key":"start_date","type":"date","label":"起始日期"}],"updatedAt":1782749735877},{"id":"cwt-1782749821511-9xx8","name":"复古小手机","size":"large","html":"<div class=\"phone\">\n  <div class=\"top\">\n    <div class=\"speaker\"></div>\n    <div class=\"logo\">TINY TYPE</div>\n    <div class=\"smiley\">☺</div>\n  </div>\n\n  <div class=\"lcd\">\n    <div class=\"lcd-top\">\n      <span id=\"lcdMode\">📞</span>\n      <span id=\"lcdTime\">--:--</span>\n      <span class=\"batt\">▮▮▮▮</span>\n    </div>\n    <div class=\"lcd-body\" id=\"screenBody\">\n      <div class=\"msg-text hint\">带你回到05年的夏天<br>連按 # 主畫面</div>\n    </div>\n    <div class=\"lcd-bottom\" id=\"screenBottom\"></div>\n  </div>\n\n  <div class=\"soft-row\">\n    <div class=\"soft\" id=\"callBtn\"><div class=\"ic ic-call\"></div></div>\n    <div class=\"dpad\"><div class=\"dpad-c\"></div></div>\n    <div class=\"soft\" id=\"endBtn\"><div class=\"ic ic-end\"></div></div>\n  </div>\n\n  <div class=\"keypad\">\n    <div class=\"key\" data-k=\"1\"><b>1</b><i>经期</i></div>\n    <div class=\"key\" data-k=\"2\"><b>2</b><i>记账</i></div>\n    <div class=\"key\" data-k=\"3\"><b>3</b><i>打卡</i></div>\n    <div class=\"key\" data-k=\"4\"><b>4</b><i>选餐</i></div>\n    <div class=\"key\" data-k=\"5\"><b>5</b><i>纪念日</i></div>\n    <div class=\"key\" data-k=\"6\"><b>6</b><i>统计</i></div>\n    <div class=\"key\" data-k=\"7\"><b>7</b><i></i></div>\n    <div class=\"key\" data-k=\"8\"><b>8</b><i></i></div>\n    <div class=\"key\" data-k=\"9\"><b>9</b><i></i></div>\n    <div class=\"key\" data-k=\"*\"><b>*</b><i>⌫</i></div>\n    <div class=\"key\" data-k=\"0\"><b>0</b><i></i></div>\n    <div class=\"key\" data-k=\"#\"><b>#</b><i>小数点</i></div>\n  </div>\n</div>\n\n<script>\nwidget.onReady(async () => {\n  const periodDate = (await widget.getState('period_date')) ?? '';\n  const periodCycle = +((await widget.getState('period_cycle')) ?? 28);\nconst monthBudget = +((await widget.getState('month_budget')) ?? 0);\n  const diceRaw = (await widget.getState('dice_options')) ?? '火鍋|燒烤|沙拉|麥當勞|不吃了';\n  const annivDate = (await widget.getState('anniv_date')) ?? '';\n  const annivLabel = (await widget.getState('anniv_label')) ?? '紀念日';\n\n  const todayKey = () => { const d=new Date(); return `${d.getFullYear()}-${d.getMonth()+1}-${d.getDate()}`; };\n  const pad = n => String(n).padStart(2,'0');\n  const pick = arr => arr[Math.floor(Math.random()*arr.length)];\n  // 金額格式化：整數不顯示小數，有零頭才顯示兩位\n  const fmtMoney = n => Number.isInteger(n) ? String(n) : n.toFixed(2);\n\n  const lcdTime = document.getElementById('lcdTime');\n  function updTime(){ const d=new Date(); lcdTime.textContent = pad(d.getHours())+':'+pad(d.getMinutes()); }\n  updTime(); setInterval(updTime, 30000);\n\n  function fnPeriod() {\n    if (!periodDate) return '請先設置\\n經期日期~';\n    const last = new Date(periodDate.replace(/-/g,'/')).getTime();\n    if (isNaN(last)) return '日期格式錯誤';\n    const passed = Math.floor((Date.now()-last)/86400000);\n    const remain = periodCycle - (passed % periodCycle);\n    if (remain <= 2) return `姨媽快到啦!\\n還有 ${remain} 天\\n備好衛生巾~`;\n    if (remain <= 7) return `距下次經期\\n${remain} 天\\n要照顧自己❤`;\n    return `距下次經期\\n還有 ${remain} 天`;\n  }\n\n  async function fnWater() {\n    const k = 'water_' + todayKey();\n    let n = +((await widget.getState(k)) ?? 0);\n    n++;\n    await widget.setState(k, n);\n    let tip = '繼續加油~';\n    if (n >= 8) tip = '達標啦!💧';\n    else if (n >= 4) tip = '不錯哦~';\n    return `今日已喝水\\n${n} 杯　${tip}`;\n  }\n\n  function fnDice() {\n    const arr = diceRaw.split('|').map(s=>s.trim()).filter(Boolean);\n    if (!arr.length) return '請先設置選項';\n    return '🎲 結果:\\n' + pick(arr);\n  }\n\n  function fnAnniv() {\n    if (!annivDate) return '請設置紀念日';\n    const t = new Date(annivDate.replace(/-/g,'/')).getTime();\n    if (isNaN(t)) return '日期錯誤';\n    const days = Math.ceil((t - Date.now())/86400000);\n    if (days > 0) return `距${annivLabel}\\n還有 ${days} 天`;\n    if (days === 0) return `今天就是\\n${annivLabel}!🎉`;\n    return `${annivLabel}\\n已過 ${-days} 天`;\n  }\n\n  // 本月帳單統計（按 6）\n  async function fnStats() {\n    const bills = await getBills();\n    const now = new Date();\n    const ym = now.getFullYear()+'-'+now.getMonth();\n    const month = bills.filter(b => {\n      const d = new Date(b.t);\n      return d.getFullYear()+'-'+d.getMonth() === ym;\n    });\n    if (!month.length) return '本月還沒\\n記賬哦~';\n    const total = month.reduce((s,b)=>s+b.a, 0);\n    const days = new Set(month.map(b=>new Date(b.t).getDate())).size;\n    const avg = total / days;\n    return `本月 ${month.length} 筆\\n合計 ¥${fmtMoney(total)}\\n日均 ¥${fmtMoney(avg)}`;\n  }\n\n  let mode = 'call';\n  let buffer = '';\n  let viewingDetail = false;\n  const bodyEl = document.getElementById('screenBody');\n  const bottomEl = document.getElementById('screenBottom');\n  const modeEl = document.getElementById('lcdMode');\n\n  function showText(text) {\n    bodyEl.innerHTML = `<div class=\"msg-text\">${text.replace(/\\n/g,'<br>')}</div>`;\n  }\n\n  async function getBills(){\n    let b = await widget.getState('bills');\n    if (!b) {\n      const backup = (await widget.getState('bills_backup')) ?? '';\n      try { b = backup ? JSON.parse(backup) : []; } catch { b = []; }\n      await widget.setState('bills', b);\n    }\n    return b;\n  }\n\n  async function saveBills(b){\n    await widget.setState('bills', b);\n    await widget.setState('bills_backup', JSON.stringify(b));\n  }\n\n  async function addBill(amt){\n    const b = await getBills();\n    b.push({a:amt, t:Date.now()});\n    await saveBills(b);\n  }\n  async function delBill(i){\n    const b = await getBills();\n    b.splice(i,1);\n    await saveBills(b);\n  }\n\n  async function calcSums() {\n    const bills = await getBills();\n    const today = new Date().toDateString();\n    const ym = (d=>d.getFullYear()+'-'+d.getMonth())(new Date());\n    let ts=0, ms=0;\n    bills.forEach(b => {\n      const d = new Date(b.t);\n      if (d.toDateString()===today) ts+=b.a;\n      if (d.getFullYear()+'-'+d.getMonth()===ym) ms+=b.a;\n    });\n    return { ts, ms, bills };\n  }\n  async function refreshBottom() {\n  if (mode === 'bill') {\n    const {ts, ms} = await calcSums();\n    if (monthBudget > 0) {\n      const remain = monthBudget - ms;\n      if (remain >= 0) {\n        bottomEl.textContent = `月¥${fmtMoney(ms)} 剩¥${fmtMoney(remain)}`;\n        bottomEl.style.color = '';\n      } else {\n        bottomEl.textContent = `已超支 ¥${fmtMoney(-remain)}!`;\n        bottomEl.style.color = '#c83030';\n      }\n    } else {\n      bottomEl.textContent = `今日¥${fmtMoney(ts)} 月¥${fmtMoney(ms)}`;\n      bottomEl.style.color = '';\n    }\n  } else {\n    const d = new Date();\n    bottomEl.textContent = `${d.getFullYear()}/${pad(d.getMonth()+1)}/${pad(d.getDate())}`;\n    bottomEl.style.color = '';\n  }\n}\n\n  async function refresh() {\n    viewingDetail = false;\n    if (mode === 'call') {\n      modeEl.textContent = '📞';\n      bodyEl.innerHTML = '<div class=\"msg-text hint\">带你回到05年的夏天<br>連按兩下 # 主畫面</div>';\n    } else {\n      modeEl.textContent = '💰';\n      bodyEl.innerHTML = `<div class=\"msg-text big\">¥ ${buffer || '0'}</div><div class=\"hint-sm\">📞入賬 #小數點 *刪</div>`;\n    }\n    await refreshBottom();\n  }\n  refresh();\n\n  // ===== 按鍵：雙擊代替長按 =====\n  const DOUBLE_MS = 400;\n  const lastTap = {};\n\n  document.querySelectorAll('.key').forEach(el => {\n    const k = el.dataset.k;\n    el.addEventListener('pointerdown', () => el.classList.add('pressed'));\n    el.addEventListener('pointerleave', () => el.classList.remove('pressed'));\n\n    el.addEventListener('pointerup', async () => {\n      el.classList.remove('pressed');\n      const now = Date.now();\n      const isDouble = lastTap[k] && (now - lastTap[k] < DOUBLE_MS);\n      lastTap[k] = isDouble ? 0 : now;\n\n      // # 鍵：雙擊回主畫面；記賬模式下單擊當小數點\n      if (k === '#') {\n        if (isDouble) {\n          mode = 'call';\n          buffer = '';\n          refresh();\n          return;\n        }\n        if (mode === 'bill' && !viewingDetail && !buffer.includes('.')) {\n          buffer = (buffer || '0') + '.';\n          refresh();\n        }\n        return;\n      }\n\n      // 雙擊 * 看賬單明細\n      if (k === '*' && isDouble) {\n        if (mode !== 'bill') mode = 'bill';\n        await showBillDetail();\n        await refreshBottom();\n        return;\n      }\n\n      // 從明細退出\n      if (viewingDetail && k !== '*') {\n        viewingDetail = false;\n        refresh();\n        return;\n      }\n\n      if (mode === 'call') {\n        switch (k) {\n          case '1': showText(fnPeriod()); return;\n          case '2': mode = 'bill'; buffer = ''; refresh(); return;\n          case '3': showText(await fnWater()); return;\n          case '4': showText(fnDice()); return;\n          case '5': showText(fnAnniv()); return;\n          case '6': showText(await fnStats()); return;\n        }\n      } else {\n        if (/[0-9]/.test(k)) {\n          const dot = buffer.indexOf('.');\n          if (dot >= 0) {\n            // 小數點後最多 2 位\n            if (buffer.length - dot - 1 < 2) buffer += k;\n          } else {\n            if (buffer.length < 7) buffer += k;\n          }\n          refresh();\n        } else if (k === '*') {\n          buffer = buffer.slice(0, -1);\n          refresh();\n        }\n      }\n    });\n  });\n\n  document.getElementById('callBtn').onclick = async () => {\n    if (mode === 'bill' && buffer) {\n      const amt = +buffer;\n      if (!isNaN(amt) && amt > 0) {\n        await addBill(amt);\n        buffer = '';\n        await refresh();\n      }\n    }\n  };\n  document.getElementById('endBtn').onclick = () => {\n    mode = 'call';\n    buffer = '';\n    refresh();\n  };\n});\n</script>","css":"* { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml, body {\n  width: 100%; height: 100%;\n  background: transparent;\n  font-family: -apple-system, \"PingFang SC\", sans-serif;\n  overflow: hidden;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* ===== 機身：豎版小巧 ===== */\n.phone {\n  width: 64%;\n  max-width: 200px;\n  height: 96%;\n  background: linear-gradient(135deg, #e8e8ec 0%, #c8c8cc 50%, #dcdce0 100%);\n  border-radius: 16px;\n  padding: 4px 5px 5px;\n  display: flex;\n  flex-direction: column;\n  gap: 3px;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,1),\n    inset 0 -2px 4px rgba(0,0,0,.12),\n    0 5px 14px rgba(0,0,0,.3);\n  border: 1px solid rgba(0,0,0,.12);\n}\n\n/* 頂部 */\n.top {\n  position: relative;\n  height: 14px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n.speaker {\n  position: absolute; top: 1px; left: 50%;\n  transform: translateX(-50%);\n  width: 24%; height: 2.5px;\n  background: #5a5a60;\n  border-radius: 2px;\n  box-shadow: inset 0 1px 1px rgba(0,0,0,.5);\n}\n.logo {\n  font-size: 6.5px;\n  font-weight: 800;\n  color: #4a4a52;\n  letter-spacing: 1px;\n  margin-top: 4px;\n}\n.smiley {\n  position: absolute; right: 0; top: 1px;\n  width: 11px; height: 11px;\n  background: #ffd84a;\n  border-radius: 50%;\n  display: flex; align-items: center; justify-content: center;\n  font-size: 7px; color: #333;\n  box-shadow: 0 1px 2px rgba(0,0,0,.2);\n}\n\n/* ===== LCD 螢幕 ===== */\n.lcd {\n  flex: 0 0 36%;\n  background: repeating-linear-gradient(0deg, #a8d860 0, #a8d860 1.5px, #9fce58 1.5px, #9fce58 2px);\n  border-radius: 4px;\n  padding: 3px 5px;\n  display: flex;\n  flex-direction: column;\n  gap: 1px;\n  box-shadow: inset 0 2px 4px rgba(0,0,0,.35), inset 0 0 8px rgba(80,120,40,.4);\n  border: 1.5px solid #5a5a60;\n  font-family: \"VT323\", \"Press Start 2P\", \"Courier New\", monospace;\n  color: #1a2a10;\n  overflow: hidden;\n}\n.lcd-top {\n  display: flex; justify-content: space-between; align-items: center;\n  font-size: 7.5px; font-weight: 700;\n  border-bottom: 1px solid rgba(0,0,0,.18);\n  padding-bottom: 1px;\n}\n.lcd-top .batt { letter-spacing: -2px; }\n.lcd-body {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  font-size: 15px;\n  line-height: 1.4;\n  font-weight: 700;\n  overflow: hidden;\n  padding: 2px 0;\n  letter-spacing: .3px;\n  min-height: 0;\n}\n.msg-text { width: 100%; word-break: break-word; text-align: center; }\n.msg-text.hint { font-size: 12px; opacity: .7; }\n.msg-text.big { font-size: 18px; font-weight: 800; letter-spacing: 1px; }\n.hint-sm { font-size: 8px; opacity: .65; margin-top: 2px; }\n.lcd-bottom {\n  font-size: 6.5px; font-weight: 700;\n  border-top: 1px solid rgba(0,0,0,.18);\n  padding-top: 1px;\n}\n.bill-list { font-size: 7px; line-height: 1.4; }\n.bill-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed rgba(0,0,0,.2); }\n.bill-item .del { color: #c83030; cursor: pointer; font-weight: 800; padding: 0 2px; }\n\n/* ===== 軟鍵區 ===== */\n.soft-row {\n  flex: 0 0 13%;\n  min-height: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 2px;\n}\n.soft {\n  width: 28%; height: 100%;\n  background: linear-gradient(180deg, #2a2a30 0%, #1a1a20 100%);\n  border-radius: 9px 9px 5px 5px;\n  display: flex; align-items: center; justify-content: center;\n  cursor: pointer;\n  box-shadow: inset 0 1px 0 rgba(255,255,255,.15), 0 1px 2px rgba(0,0,0,.3);\n}\n.soft:active { transform: translateY(1px); }\n.ic { width: 14px; height: 14px; background-repeat: no-repeat; background-position: center; background-size: contain; }\n.ic-call {\n  background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%234ade80' d='M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2a11 11 0 003.5.6c.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 013 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.3 0 .7-.2 1z'/></svg>\");\n}\n.ic-end {\n  background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%23ff5050' d='M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2a11 11 0 003.5.6c.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 013 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.3 0 .7-.2 1z' transform='rotate(135 12 12)'/></svg>\");\n}\n\n/* 中央方向鍵 */\n.dpad {\n  width: 38%; height: 100%;\n  background: radial-gradient(ellipse at 50% 30%, #f4f4f8 0%, #c4c4cc 70%, #a4a4ac 100%);\n  border-radius: 50%;\n  display: flex; align-items: center; justify-content: center;\n  box-shadow:\n    inset 0 1px 1px rgba(255,255,255,.95),\n    inset 0 -1px 2px rgba(0,0,0,.2),\n    0 1px 2px rgba(0,0,0,.3);\n}\n.dpad-c {\n  width: 50%; height: 55%;\n  background: linear-gradient(180deg, #2a2a30, #15151a);\n  border-radius: 4px;\n  box-shadow: inset 0 1px 1px rgba(255,255,255,.1), inset 0 -1px 2px rgba(0,0,0,.5);\n}\n\n/* ===== 鍵盤（白鍵） ===== */\n.keypad {\n  flex: 1;\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  grid-template-rows: repeat(4, 1fr);\n  gap: 2px;\n  background: #2a2a30;\n  padding: 2px;\n  border-radius: 5px;\n  box-shadow: inset 0 1px 3px rgba(0,0,0,.5);\n  min-height: 0;\n}\n.key {\n  background: linear-gradient(180deg, #ffffff 0%, #e0e0e4 100%);\n  border-radius: 3px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 3px;\n  cursor: pointer;\n  user-select: none;\n  color: #1a1a20;\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,1),\n    inset 0 -1px 1px rgba(0,0,0,.15),\n    0 1px 1px rgba(0,0,0,.15);\n  transition: transform .08s, box-shadow .08s;\n  padding: 1px 2px;\n  min-width: 0;\n  overflow: hidden;\n  border: 1px solid rgba(0,0,0,.08);\n}\n.key.pressed,\n.key:active {\n  transform: translateY(1px);\n  box-shadow: inset 0 1px 3px rgba(0,0,0,.2);\n  background: linear-gradient(180deg, #e8e8ec 0%, #d0d0d4 100%);\n}\n.key b {\n  font-size: 11px;\n  font-weight: 800;\n  font-family: \"Arial Black\", sans-serif;\n  line-height: 1;\n  color: #1a1a20;\n}\n.key i {\n  font-size: 7px;\n  font-style: normal;\n  line-height: 1;\n}","images":{},"userFields":[{"key":"period_date","label":"上次经期日期","type":"date"},{"key":"period_cycle","label":"经期周期","type":"number"},{"key":"dice_options","label":"外卖可选","type":"text"},{"key":"anniv_date","label":"纪念日日期","type":"date"},{"key":"anniv_label","label":"纪念日名称","type":"text"},{"key":"month_budget","label":"月预算","type":"number"},{"key":"bills_backup","label":"账单备份（勿手动修改）","type":"text"}],"updatedAt":1782749821511},{"id":"cwt-1783348277067-vvnh","name":"可动桌宠框架多功能byAkoasm","size":"large","html":"","css":".my-custom-box {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  background: #fff;\n  border-radius: 20px;\n}\n.my-custom-box img {\n  width: 50px;\n  height: 50px;\n  border-radius: 50%;\n}","images":{"normal":"data:image/png;base64,","eat":"","sleep":"","play":"","study":"","bg_home":"","bg_out":"","bg_in_bed":"","bg_in_desk":"","bg_in_kitchen":"","bg_in_play":"","bg_in_shop":"","bg_in_grass":"","icon_bed":"","icon_desk":"","icon_kitchen":"","icon_play":"","icon_shop":"","icon_grass":""},"userFields":[{"type":"text","label":"宠物名字","key":"petName"},{"type":"date","label":"上次经期","key":"lastPeriod"},{"type":"number","label":"周期天数","key":"cycleDays"}],"updatedAt":1783359106398}]