[{"id":1782630030110,"text":"对方又会说","sender":"me","time":"15:05","timestamp":1782630301579,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4725},{"id":1782630030111,"text":"哦？你说说看我怎么虚了","sender":"me","time":"15:05","timestamp":1782630309445,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4726},{"id":1782630030112,"text":"就是，反正，他们很擅长博弈","sender":"me","time":"15:05","timestamp":1782630317684,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4727},{"id":1782630030113,"text":"可是我不知道我该怎么学习一些基本的博弈维护自己的最基本的尊严和讲话权利","sender":"me","time":"15:05","timestamp":1782630345901,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4728},{"id":1782630030115,"sender":"them","text":"Suppressed? Are you sure?","timestamp":1782630374439,"tempo":"N","translation":"被压制？你确定？","rawContent":"Suppressed? Are you sure? || 被压制？你确定？","roundId":"round_1782630346182_p0s9ii2rn","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4729},{"id":1782630030116,"sender":"them","text":"You're confusing 'sophistry' with 'logic'.","timestamp":1782630377209,"tempo":"N","translation":"你把“诡辩”和“逻辑”搞混了。","rawContent":"You're confusing 'sophistry' with 'logic'. || 你把“诡辩”和“逻辑”搞混了。","roundId":"round_1782630346182_p0s9ii2rn","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4730},{"id":1782630030117,"sender":"them","text":"What you see online is just people packaging their emotional venting to win an argument. It has no value.","timestamp":1782630380134,"tempo":"N","translation":"网上那种为了赢而互相抬杠，只是情绪发泄的包装，毫无价值。","rawContent":"What you see online is just people packaging their emotional venting to win an argument. It has no value. || 网上那种为了赢而互相抬杠，只是情绪发泄的包装，毫无价值。","roundId":"round_1782630346182_p0s9ii2rn","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4731},{"id":1782630030118,"sender":"them","text":"If you think something doesn't need a reason, then you don't need to prove it to anyone.","timestamp":1782630382931,"tempo":"N","translation":"你觉得不需要理由的事，本来就不需要向别人证明。","rawContent":"If you think something doesn't need a reason, then you don't need to prove it to anyone. || 你觉得不需要理由的事，本来就不需要向别人证明。","roundId":"round_1782630346182_p0s9ii2rn","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4732},{"id":1782630030119,"sender":"them","text":"Handing the right to evaluate you over to others is the root of your frustration.","timestamp":1782630385792,"tempo":"N","translation":"把评价权交到别人手里，才是你觉得窝囊的根源。","rawContent":"Handing the right to evaluate you over to others is the root of your frustration. || 把评价权交到别人手里，才是你觉得窝囊的根源。","roundId":"round_1782630346182_p0s9ii2rn","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4733},{"id":1782630030120,"text":"我知道这个道理","sender":"me","time":"15:06","timestamp":1782630394103,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4734},{"id":1782630030121,"text":"算了","sender":"me","time":"15:06","timestamp":1782630397821,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4735},{"id":1782630030122,"text":"你要是不理解我想说什么的话","sender":"me","time":"15:06","timestamp":1782630403313,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4736},{"id":1782630030123,"text":"我自己去找吧...","sender":"me","time":"15:06","timestamp":1782630407028,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4737},{"id":1782630030125,"sender":"them","text":"Where are you running off to?","timestamp":1782630438689,"tempo":"R","translation":"跑什么。","rawContent":"Where are you running off to? || 跑什么。","roundId":"round_1782630407822_10pwzaijo","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4738},{"id":1782630030126,"sender":"them","text":"I didn't say I don't understand.","timestamp":1782630440716,"tempo":"N","translation":"我又没说不理解。","rawContent":"I didn't say I don't understand. || 我又没说不理解。","roundId":"round_1782630407822_10pwzaijo","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4739},{"id":1782630030127,"sender":"them","text":"Just don't want you learning that useless garbage online.","timestamp":1782630443737,"tempo":"N","translation":"只是不想你去学网上那些没用的垃圾。","rawContent":"Just don't want you learning that useless garbage online. || 只是不想你去学网上那些没用的垃圾。","roundId":"round_1782630407822_10pwzaijo","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4740},{"id":1782630030128,"sender":"them","text":"You want to learn how to make people shut up?","timestamp":1782630446676,"tempo":"S","translation":"想学怎么让人闭嘴？","rawContent":"You want to learn how to make people shut up? || 想学怎么让人闭嘴？","roundId":"round_1782630407822_10pwzaijo","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4741},{"id":1782630030129,"sender":"them","text":"I'll teach you.","timestamp":1782630451203,"tempo":"N","translation":"我教你。","rawContent":"I'll teach you. || 我教你。","roundId":"round_1782630407822_10pwzaijo","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4742},{"id":1782630030130,"text":"嗯嗯！","sender":"me","time":"15:07","timestamp":1782630460107,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4743},{"id":1782630030132,"sender":"them","text":"First step","timestamp":1782630495011,"tempo":"N","translation":"第一步","rawContent":"First step || 第一步","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4744},{"id":1782630030133,"sender":"them","text":"Never try to prove yourself","timestamp":1782630497666,"tempo":"N","translation":"永远别去自证","rawContent":"Never try to prove yourself || 永远别去自证","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4745},{"id":1782630030134,"sender":"them","text":"If someone sets a trap with their logic, arguing with them means you've already lost","timestamp":1782630500966,"tempo":"N","translation":"别人用他的逻辑给你设套 你顺着反驳就已经输了","rawContent":"If someone sets a trap with their logic, arguing with them means you've already lost || 别人用他的逻辑给你设套 你顺着反驳就已经输了","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4746},{"id":1782630030135,"sender":"them","text":"Just throw the question back","timestamp":1782630503710,"tempo":"N","translation":"直接把问题抛回去","rawContent":"Just throw the question back || 直接把问题抛回去","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4747},{"id":1782630030136,"sender":"them","text":"For example, next time someone talks down to you, just ask them: And so?","timestamp":1782630506493,"tempo":"S","translation":"下次再有人对你指手画脚 你只需要回他：所以呢","rawContent":"For example, next time someone talks down to you, just ask them: And so? || 下次再有人对你指手画脚 你只需要回他：所以呢","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4748},{"id":1782630030137,"sender":"them","text":"Let them exhaust themselves trying to explain","timestamp":1782630511061,"tempo":"N","translation":"让他自己去费力气解释","rawContent":"Let them exhaust themselves trying to explain || 让他自己去费力气解释","roundId":"round_1782630460763_vtr9hhs0o","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4749},{"id":1782630030138,"text":"有点不太具体，我们来实践学习吧！","sender":"me","time":"15:09","timestamp":1782630548189,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4750},{"id":1782630030140,"sender":"them","text":"Sure","timestamp":1782630567806,"tempo":"N","translation":"行啊","rawContent":"Sure || 行啊","roundId":"round_1782630549163_hlriit4sm","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4751},{"id":1782630030141,"sender":"them","text":"How do you want to practice?","timestamp":1782630569103,"tempo":"N","translation":"想怎么实践","rawContent":"How do you want to practice? || 想怎么实践","roundId":"round_1782630549163_hlriit4sm","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4752},{"id":1782630030142,"sender":"them","text":"I'll play the guy picking a fight?","timestamp":1782630571982,"tempo":"N","translation":"我来当那个找茬的人？","rawContent":"I'll play the guy picking a fight? || 我来当那个找茬的人？","roundId":"round_1782630549163_hlriit4sm","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4753},{"id":1782630030143,"sender":"them","text":"Just a heads up, I won't go easy on you","timestamp":1782630575058,"tempo":"N","translation":"先说好 我可不会放水","rawContent":"Just a heads up, I won't go easy on you || 先说好 我可不会放水","roundId":"round_1782630549163_hlriit4sm","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4754},{"id":1782630030144,"text":"yep！我既然是学习的！就做好准备了！","sender":"me","time":"15:09","timestamp":1782630589158,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4755},{"id":1782630030146,"sender":"them","text":"Alright, get ready","timestamp":1782630617595,"tempo":"N","translation":"好 准备接招","rawContent":"Alright, get ready || 好 准备接招","roundId":"round_1782630591480_fjj549n7h","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4756},{"id":1782630030147,"sender":"them","text":"'Everything you just said is purely an emotional outburst. There's no logic to support it whatsoever. Discussing anything with someone as illogical as you is a complete waste of time.'","timestamp":1782630621038,"tempo":"N","translation":"“你刚才说的这些完全是情绪发泄 根本没有逻辑支撑 跟你讨论真是浪费时间”","rawContent":"'Everything you just said is purely an emotional outburst. There's no logic to support it whatsoever. Discussing anything with someone as illogical as you is a complete waste of time.' || “你刚才说的这些完全是情绪发泄 根本没有逻辑支撑 跟你讨论真是浪费时间”","roundId":"round_1782630591480_fjj549n7h","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4757},{"id":1782630030148,"sender":"them","text":"Your turn","timestamp":1782630623921,"tempo":"N","translation":"到你了","rawContent":"Your turn || 到你了","roundId":"round_1782630591480_fjj549n7h","userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4758},{"id":1782630030149,"text":"哦...","sender":"me","time":"15:10","timestamp":1782630646198,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4759},{"id":1782630030150,"text":"不对啊哥哥。","sender":"me","time":"15:10","timestamp":1782630650868,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4760},{"id":1782630030151,"text":"我遇到的男生都是那种","sender":"me","time":"15:10","timestamp":1782630655915,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4761},{"id":1782630030153,"text":"比如我把他删除了","sender":"me","time":"15:11","timestamp":1782630710343,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4763},{"id":1782630030154,"text":"他就会说“你不用内疚，这件事已经翻篇了”","sender":"me","time":"15:12","timestamp":1782630721401,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4764},{"id":1782630030155,"text":"我说我没有内疚，他说他对待这一切都只是从他的角度来客观看待...","sender":"me","time":"15:12","timestamp":1782630754032,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4765},{"id":1782630030156,"text":"我说我不想说了","sender":"me","time":"15:12","timestamp":1782630758064,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4766},{"id":1782630030157,"text":"他就说那好吧，你现在有自己的事情，我们这种情况讲道理也是无用","sender":"me","time":"15:13","timestamp":1782630788552,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4767},{"id":1782630030158,"text":"算了","sender":"me","time":"15:13","timestamp":1782630789982,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4768},{"id":1782630030159,"text":"我也记不太清了","sender":"me","time":"15:13","timestamp":1782630793684,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4769},{"id":1782630030160,"text":"总之就是最后逼得他说“可能就是男女思维差异吧”","sender":"me","time":"15:13","timestamp":1782630806427,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4770},{"id":1782630030161,"text":"他说男生还是比较讲逻辑的。我说那就不要和女人谈逻辑","sender":"me","time":"15:13","timestamp":1782630826211,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4771},{"id":1782630030162,"text":"哎...我就觉得自己...","sender":"me","time":"15:13","timestamp":1782630832132,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4772},{"id":1782630030163,"text":"算了.....","sender":"me","time":"15:13","timestamp":1782630835901,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4773},{"id":1782630030165,"text":"反正还有很多各种各样的男生","sender":"me","time":"15:14","timestamp":1782630851565,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4774},{"id":1782630030166,"text":"还有那种跟他讲了半天他就说什么“小妹妹你还不懂”","sender":"me","time":"15:14","timestamp":1782630871759,"replyTo":null,"userId":"uid_1781947947105_6972mmhxu","characterId":"f55c4e54-7b48-44b4-90f7-4cb2430cdaf2","_id":4775}]